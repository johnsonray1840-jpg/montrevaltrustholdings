<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Montreval Trust Holdings - Trust Application Details">
    <link rel="icon" href="/images/favicon.png">
    <title>Trust Details | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg-card: rgba(255, 255, 255, 0.03);
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-dark: #0f172a;
        }

        html, body {
            min-height: 100vh;
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
        }

        .dashboard { padding: 20px 0 60px; min-height: calc(100vh - 80px); }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 30px;
            align-items: start;
        }

        /* Sidebar */
        .sidebar {
            background: var(--brand-bg-card);
            border: 1px solid var(--brand-border);
            border-radius: 20px;
            padding: 24px;
            backdrop-filter: blur(10px);
            position: sticky;
            top: 100px;
        }
        
        .user-profile {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid var(--brand-border);
            margin-bottom: 20px;
        }
        
        .user-avatar {
            width: 80px; height: 80px;
            margin: 0 auto 15px;
            background: var(--brand-dark);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid rgba(255,255,255,0.15);
        }
        
        .user-avatar i { font-size: 3rem; color: var(--brand-white); }
        .user-profile h4 { margin-bottom: 4px; color: var(--brand-white); }
        .user-profile p { color: var(--brand-gray); font-size: 0.9rem; }
        
        .sidebar-nav { list-style: none; padding: 0; }
        .sidebar-nav li { margin-bottom: 6px; }
        
        .sidebar-nav a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px; color: var(--brand-gray);
            text-decoration: none; border-radius: 10px;
            transition: all 0.3s; font-size: 0.95rem;
        }
        
        .sidebar-nav a:hover { background: rgba(255, 255, 255, 0.05); color: var(--brand-white); }
        .sidebar-nav li.active a { background: var(--brand-dark); color: var(--brand-white); border: 1px solid rgba(255,255,255,0.1); }
        .sidebar-nav i { width: 20px; }

        /* Content */
        .content-area { padding: 0; }
        .dashboard-header { margin-bottom: 20px; }
        
        .back-link {
            color: var(--brand-gray); text-decoration: none; font-size: 0.9rem;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .back-link:hover { color: var(--brand-white); }
        
        .dashboard-header h1 { margin-top: 10px; color: var(--brand-white); font-size: clamp(1.5rem, 3vw, 2rem); }

        /* Badges */
        .badge {
            display: inline-block; padding: 6px 14px;
            border-radius: 100px; font-size: 0.8rem; font-weight: 600;
        }
        .badge-pending { background: rgba(245,158,11,0.2); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.2); color: var(--success); }
        .badge-active { background: rgba(34,197,94,0.2); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.2); color: var(--danger); }
        .badge-draft { background: rgba(148,163,184,0.2); color: var(--brand-gray); }
        .badge-under_review { background: rgba(59,130,246,0.2); color: #3b82f6; }

        /* Status Timeline */
        .status-timeline {
            display: flex; align-items: center; justify-content: space-between;
            margin: 30px 0; padding: 20px;
            background: var(--brand-bg-card);
            border: 1px solid var(--brand-border);
            border-radius: 12px;
        }
        
        .timeline-step { text-align: center; flex: 1; }
        
        .timeline-step .step-icon {
            width: 40px; height: 40px; margin: 0 auto 10px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--brand-gray);
        }
        
        .timeline-step.completed .step-icon {
            background: var(--success); color: white;
        }
        
        .timeline-connector {
            width: 60px; height: 2px;
            background: var(--brand-border);
        }
        
        .timeline-connector.completed { background: var(--success); }
        
        .step-label { font-weight: 500; margin-bottom: 4px; font-size: 0.85rem; color: var(--brand-white); }
        .step-date { font-size: 0.75rem; color: var(--brand-gray); }

        /* Detail Grid */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin: 20px 0;
        }
        
        .detail-section {
            background: var(--brand-bg-card);
            border: 1px solid var(--brand-border);
            border-radius: 12px;
            padding: 20px;
        }
        
        .detail-section.full-width { grid-column: span 2; }
        
        .detail-section h3 { margin-bottom: 15px; font-size: 1.1rem; color: var(--brand-white); display: flex; align-items: center; gap: 8px; }
        .detail-section h3 i { color: var(--brand-white); font-size: 1rem; }
        
        .detail-table { width: 100%; }
        
        .detail-table th {
            text-align: left; width: 40%;
            color: var(--brand-gray); font-weight: 500;
            padding: 10px 0; font-size: 0.85rem;
        }
        
        .detail-table td {
            color: var(--brand-white);
            padding: 10px 0; font-size: 0.9rem;
        }

        /* Document List */
        .document-list { list-style: none; padding: 0; }
        
        .document-list li {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 0; border-bottom: 1px solid var(--brand-border);
            color: var(--brand-white);
        }
        
        .document-list li:last-child { border-bottom: none; }
        .document-list li small { color: var(--brand-gray); margin-left: auto; }

        /* Wallet Card */
        .wallet-card {
            margin-top: 30px; padding: 24px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--brand-border);
            border-radius: 16px;
            display: flex; align-items: center; gap: 20px;
            flex-wrap: wrap;
        }
        
        .wallet-card strong { color: var(--brand-white); display: block; margin-bottom: 4px; }
        .wallet-card p { color: var(--brand-gray); margin: 0; font-size: 0.9rem; }

        .text-muted { color: var(--brand-gray); }

        /* Buttons */
        .btn {
            padding: 10px 20px; border-radius: 10px;
            font-weight: 600; font-size: 0.9rem;
            cursor: pointer; transition: all 0.3s;
            display: inline-flex; align-items: center; gap: 8px;
            border: none; text-decoration: none;
        }
        .btn-primary { background: var(--brand-dark); color: var(--brand-white); border: 1px solid rgba(255,255,255,0.15); }
        .btn-primary:hover { background: #2d4257; transform: translateY(-2px); }
        .btn-success { background: var(--success); color: #fff; }
        .btn-success:hover { background: #16a34a; }
        .btn-lg { padding: 16px 32px; font-size: 1.1rem; }

        @media (max-width: 900px) {
            .dashboard-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .detail-grid { grid-template-columns: 1fr; }
            .detail-section.full-width { grid-column: span 1; }
            .status-timeline { flex-direction: column; gap: 15px; }
            .timeline-connector { width: 2px; height: 30px; }
        }
    </style>
</head>
<body>

    <!-- ========================= HEADER ========================= -->
    <header class="header header-layout2">
        <div class="header-topbar d-none d-sm-block">
            <div class="container-fluid h-100">
                <div class="row align-items-center h-100">
                    <div class="col-12 d-flex align-items-center justify-content-between">
                        <ul class="contact-list d-flex flex-wrap align-items-center list-unstyled mb-0">
                            <li class="d-flex align-items-center">
                                <span>Your trusted partner for secure wealth growth & financial freedom.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg sticky-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" href="/"><img src="/images/logo.png" class="logo-dark" alt="Montreval Trust Holdings"></a>
            </div>
        </nav>
    </header>

    <div class="dashboard">
        <div class="container">
            <div class="dashboard-grid">
                <!-- Sidebar -->
                <div class="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar"><i class="fas fa-user-circle"></i></div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li><a href="/user/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/user/kyc"><i class="fas fa-id-card"></i> Verification</a></li>
                        <li class="active"><a href="/user/trusts"><i class="fas fa-shield-haltered"></i> My Trusts</a></li>
                        <li><a href="/user/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                        <li><a href="/user/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </div>

                <!-- Main Content -->
                <div class="content-area">
                    <div class="dashboard-header">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 15px;">
                            <div>
                                <a href="/user/trusts" class="back-link">
                                    <i class="fas fa-arrow-left"></i> Back to My Trusts
                                </a>
                                <h1><%= application.trustName %></h1>
                                <div style="display: flex; gap: 10px; align-items: center; margin-top: 8px;">
                                    <span class="badge badge-<%= application.status %>" style="font-size: 0.9rem;"><%= application.status.replace(/_/g, ' ') %></span>
                                    <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--brand-gray);"><%= application.trustType ? application.trustType.replace(/_/g, ' ') : 'N/A' %></span>
                                </div>
                            </div>
                            <div>
                                <% if (application.status === 'approved' && !locals.walletAssigned) { %>
                                    <a href="/user/wallet/create?trust=<%= application._id %>" class="btn btn-success btn-lg">
                                        <i class="fas fa-wallet"></i> Create Wallet
                                    </a>
                                <% } else if (application.status === 'draft') { %>
                                    <a href="/apply/continue/<%= application._id %>" class="btn btn-primary btn-lg">
                                        <i class="fas fa-pen"></i> Continue Application
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Status Timeline -->
                    <div class="status-timeline">
                        <div class="timeline-step completed">
                            <div class="step-icon"><i class="fas fa-file-signature"></i></div>
                            <div class="step-label">Application Started</div>
                            <div class="step-date"><%= application.createdAt ? application.createdAt.toLocaleDateString() : '—' %></div>
                        </div>
                        <div class="timeline-connector <%= application.submittedAt ? 'completed' : '' %>"></div>
                        <div class="timeline-step <%= application.submittedAt ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-paper-plane"></i></div>
                            <div class="step-label">Submitted</div>
                            <div class="step-date"><%= application.submittedAt ? application.submittedAt.toLocaleDateString() : '—' %></div>
                        </div>
                        <div class="timeline-connector <%= application.approvedAt ? 'completed' : '' %>"></div>
                        <div class="timeline-step <%= application.approvedAt ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                            <div class="step-label">Approved</div>
                            <div class="step-date"><%= application.approvedAt ? application.approvedAt.toLocaleDateString() : '—' %></div>
                        </div>
                        <div class="timeline-connector <%= application.status === 'active' ? 'completed' : '' %>"></div>
                        <div class="timeline-step <%= application.status === 'active' ? 'completed' : '' %>">
                            <div class="step-icon"><i class="fas fa-shield-check"></i></div>
                            <div class="step-label">Active</div>
                            <div class="step-date"><%= application.trustExecutionDate ? application.trustExecutionDate.toLocaleDateString() : '—' %></div>
                        </div>
                    </div>

                    <div class="detail-grid">
                        <!-- Trust Information -->
                        <div class="detail-section">
                            <h3><i class="fas fa-shield-haltered"></i> Trust Information</h3>
                            <table class="detail-table">
                                <tr><th>Trust Name</th><td><strong><%= application.trustName %></strong></td></tr>
                                <tr><th>Trust Type</th><td><%= application.trustType ? application.trustType.replace(/_/g, ' ') : 'N/A' %></td></tr>
                                <tr><th>Jurisdiction</th><td><%= application.jurisdiction || 'N/A' %></td></tr>
                                <tr><th>Alternative Name 1</th><td><%= application.alternativeTrustName1 || '—' %></td></tr>
                                <tr><th>Alternative Name 2</th><td><%= application.alternativeTrustName2 || '—' %></td></tr>
                                <tr><th>Trust Purpose</th><td><%= application.trustPurpose ? application.trustPurpose.replace(/_/g, ' ') : 'N/A' %></td></tr>
                                <% if (application.trustPurposeOther) { %>
                                <tr><th>Purpose Detail</th><td><%= application.trustPurposeOther %></td></tr>
                                <% } %>
                            </table>
                        </div>

                        <!-- Settlor Information -->
                        <div class="detail-section">
                            <h3><i class="fas fa-user-circle"></i> Settlor (Grantor)</h3>
                            <table class="detail-table">
                                <tr><th>Full Name</th><td><%= application.settlor?.fullName || '—' %></td></tr>
                                <tr><th>Date of Birth</th><td><%= application.settlor?.dateOfBirth ? new Date(application.settlor.dateOfBirth).toLocaleDateString() : '—' %></td></tr>
                                <tr><th>Nationality</th><td><%= application.settlor?.nationality || '—' %></td></tr>
                                <tr><th>Email</th><td><%= application.settlor?.email || '—' %></td></tr>
                                <tr><th>Phone</th><td><%= application.settlor?.phone || '—' %></td></tr>
                                <tr><th>Address</th><td>
                                    <%= application.settlor?.address?.street || '' %><br>
                                    <%= application.settlor?.address?.city || '' %>, <%= application.settlor?.address?.country || '' %>
                                </td></tr>
                            </table>
                        </div>

                        <!-- Trustee Information -->
                        <div class="detail-section">
                            <h3><i class="fas fa-user-tie"></i> Trustee</h3>
                            <table class="detail-table">
                                <tr><th>Trustee Type</th><td><%= application.trustee?.type === 'montreval' ? 'Montreval Trust Holdings (Corporate)' : application.trustee?.type === 'co_trustee' ? 'Co-Trustees' : application.trustee?.type || 'N/A' %></td></tr>
                                <% if (application.trustee?.type !== 'montreval') { %>
                                <tr><th>Trustee Name</th><td><%= application.trustee?.fullName || '—' %></td></tr>
                                <tr><th>Trustee Email</th><td><%= application.trustee?.email || '—' %></td></tr>
                                <tr><th>Trustee Phone</th><td><%= application.trustee?.phone || '—' %></td></tr>
                                <% } %>
                                <tr><th>Successor Trustee</th><td><%= application.successorTrustee || '—' %></td></tr>
                            </table>
                        </div>

                        <!-- Beneficiaries -->
                        <div class="detail-section">
                            <h3><i class="fas fa-users"></i> Beneficiaries</h3>
                            <% if (application.beneficiaries && application.beneficiaries.length > 0) { %>
                                <table class="detail-table">
                                    <thead>
                                        <tr><th>Name</th><th>Relationship</th><th>Allocation</th></tr>
                                    </thead>
                                    <tbody>
                                        <% application.beneficiaries.forEach(b => { %>
                                            <tr>
                                                <td><%= b.name %></td>
                                                <td><%= b.relationship.replace(/_/g, ' ') %></td>
                                                <td><%= b.allocation %>%</td>
                                            </tr>
                                            <% if (b.walletAddress) { %>
                                            <tr><td colspan="3" style="font-size:0.75rem; color:var(--brand-gray);">Wallet: <%= b.walletAddress %></td></tr>
                                            <% } %>
                                        <% }) %>
                                    </tbody>
                                </table>
                            <% } else { %>
                                <p class="text-muted">No beneficiaries added.</p>
                            <% } %>
                        </div>

                        <!-- Assets & Value -->
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-coins"></i> Assets & Value</h3>
                            <table class="detail-table">
                                <tr><th>Estimated Value</th><td><%= application.estimatedValue || 'N/A' %></td></tr>
                                <tr><th>Asset Types</th><td><%= application.assetTypes?.length ? application.assetTypes.join(', ').replace(/_/g, ' ') : 'N/A' %></td></tr>
                                <tr><th>Source of Funds</th><td><%= application.sourceOfFunds ? application.sourceOfFunds.replace(/_/g, ' ') : 'N/A' %></td></tr>
                            </table>
                        </div>

                        <!-- Documents -->
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-file-upload"></i> Documents</h3>
                            <% if (application.documents && application.documents.length > 0) { %>
                                <ul class="document-list">
                                    <% application.documents.forEach(doc => { %>
                                        <li>
                                            <i class="fas fa-file-alt"></i>
                                            <span><%= doc.fileName %></span>
                                            <small><%= doc.uploadedAt ? doc.uploadedAt.toLocaleDateString() : '—' %></small>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } else { %>
                                <p class="text-muted">No documents uploaded.</p>
                            <% } %>
                        </div>

                        <!-- Rejection Reason -->
                        <% if (application.status === 'rejected' && application.rejectionReason) { %>
                        <div class="detail-section full-width" style="border-color: var(--danger);">
                            <h3 style="color: var(--danger);"><i class="fas fa-exclamation-triangle"></i> Rejection Reason</h3>
                            <p style="color: var(--danger);"><%= application.rejectionReason %></p>
                        </div>
                        <% } %>

                        <!-- Admin Notes -->
                        <% if (application.adminNotes && (application.status === 'approved' || application.status === 'active')) { %>
                        <div class="detail-section full-width">
                            <h3><i class="fas fa-clipboard"></i> Notes from Administrator</h3>
                            <p><%= application.adminNotes %></p>
                        </div>
                        <% } %>
                    </div>

                    <!-- Wallet Assignment -->
                    <% if (locals.walletAssigned) { %>
                        <div class="wallet-card" style="border-color: var(--success);">
                            <i class="fas fa-check-circle" style="color: var(--success); font-size: 1.5rem;"></i>
                            <div>
                                <strong>Wallet Created</strong>
                                <p>A crypto wallet has been assigned to this trust. <a href="/user/wallet" style="color: var(--brand-white);">View Wallet</a></p>
                            </div>
                        </div>
                    <% } else if (application.status === 'approved') { %>
                        <div class="wallet-card">
                            <i class="fas fa-wallet" style="color: var(--brand-white); font-size: 1.5rem;"></i>
                            <div>
                                <strong>Ready for Wallet Creation</strong>
                                <p>Your trust is approved! Create your non-custodial wallet now to manage crypto assets.</p>
                                <a href="/user/wallet/create?trust=<%= application._id %>" class="btn btn-success" style="margin-top:10px;">Create Wallet</a>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================= FOOTER ========================= -->
    <footer class="footer">
        <div class="footer-secondary">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-12">
                        <div class="footer-copyrights my-2">
                            <span class="fz-14">&copy; 2026 Montreval Trust Holdings. All Rights Reserved.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="/assets/js/libraries.js"></script>
    <script src="/assets/js/main.js"></script>
</body>
</html>