<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Montreval Trust Holdings - Secure Wealth Management Dashboard">
    <link rel="icon" href="/images/favicon.png">
    <title>Dashboard | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-light-gray: #cbd5e1;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg-card: rgba(255, 255, 255, 0.03);
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-dark: #0f172a;
        }

        html, body {
            min-height: 100vh;
            background: var(--bg-dark);
            background-attachment: fixed;
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
        }

        .dashboard {
            padding: 20px 0 60px;
            min-height: calc(100vh - 80px);
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 30px;
            align-items: start;
        }

        /* Sidebar */
        .sidebar {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--brand-border);
            border-radius: 20px;
            padding: 24px;
            backdrop-filter: blur(10px);
            position: sticky;
            top: 100px;
        }
        
        .user-profile {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid var(--brand-border);
            margin-bottom: 20px;
        }
        
        .user-avatar {
            width: 80px;
            height: 80px;
            margin: 0 auto 15px;
            background: var(--brand-dark);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid rgba(255,255,255,0.15);
        }
        
        .user-avatar i {
            font-size: 3rem;
            color: var(--brand-white);
        }
        
        .user-profile h4 {
            margin-bottom: 4px;
            color: var(--brand-white);
        }
        
        .user-profile p {
            color: var(--brand-gray);
            font-size: 0.9rem;
        }
        
        .sidebar-nav {
            list-style: none;
            padding: 0;
        }
        
        .sidebar-nav li {
            margin-bottom: 6px;
        }
        
        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--brand-gray);
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-size: 0.95rem;
        }
        
        .sidebar-nav a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--brand-white);
        }
        
        .sidebar-nav li.active a {
            background: var(--brand-dark);
            color: var(--brand-white);
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .sidebar-nav i {
            width: 20px;
        }

        /* Content */
        .content-area {
            padding: 0;
        }
        
        .dashboard-header {
            margin-bottom: 30px;
        }
        
        .dashboard-header h1 {
            margin-bottom: 8px;
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            color: var(--brand-white);
        }
        
        .dashboard-header p {
            color: var(--brand-gray);
        }

        /* KYC Widget */
        .kyc-widget {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--brand-border);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .kyc-widget-left { display: flex; align-items: center; gap: 20px; }
        
        .kyc-icon {
            width: 60px; height: 60px;
            background: var(--brand-dark);
            border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; color: var(--brand-white);
            flex-shrink: 0;
        }
        
        .kyc-info h3 { margin-bottom: 4px; font-size: 1.2rem; color: var(--brand-white); }
        .kyc-info p { color: var(--brand-gray); margin: 0; }
        
        .kyc-status-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 14px; border-radius: 100px;
            font-weight: 600; font-size: 0.9rem;
        }
        .kyc-status-badge.not-started { background: rgba(148,163,184,0.15); color: var(--brand-gray); }
        .kyc-status-badge.pending { background: rgba(245,158,11,0.15); color: var(--warning); }
        .kyc-status-badge.approved { background: rgba(34,197,94,0.15); color: var(--success); }
        .kyc-status-badge.rejected { background: rgba(239,68,68,0.15); color: var(--danger); }

        /* Quick actions */
        .quick-actions {
            display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 30px;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--brand-border);
            border-radius: 16px;
            padding: 24px;
        }
        
        .stat-icon {
            width: 50px; height: 50px;
            background: var(--brand-dark);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 16px;
        }
        
        .stat-icon i { font-size: 1.5rem; color: var(--brand-white); }
        .stat-value { font-size: 2.5rem; font-weight: 700; margin-bottom: 4px; color: var(--brand-white); }
        .stat-label { color: var(--brand-gray); }

        /* Recent section */
        .recent-section { margin-bottom: 30px; }
        .recent-section h3 { margin: 0; color: var(--brand-white); }

        /* Tables */
        .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        
        .data-table { width: 100%; border-collapse: collapse; }
        
        .data-table th {
            text-align: left; padding: 16px;
            background: rgba(255, 255, 255, 0.03);
            color: var(--brand-gray); font-weight: 500;
            border-bottom: 1px solid var(--brand-border);
            white-space: nowrap;
        }
        
        .data-table td {
            padding: 16px;
            border-bottom: 1px solid var(--brand-border);
            color: var(--brand-white);
        }
        
        .data-table tr:last-child td { border-bottom: none; }

        /* Wallet snapshot */
        .wallet-snapshot {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--brand-border);
            border-radius: 12px;
            padding: 20px;
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 20px;
        }
        
        .wallet-address { display: flex; align-items: center; gap: 10px; }
        
        .wallet-address code {
            background: rgba(0,0,0,0.3);
            padding: 8px 12px; border-radius: 8px;
            font-family: monospace; word-break: break-all;
            color: var(--brand-white);
        }
        
        .balance-label { color: var(--brand-gray); font-size: 0.9rem; }
        .balance-value { font-size: 2rem; font-weight: 700; color: var(--success); }

        /* Empty state */
        .empty-state {
            text-align: center; padding: 40px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
            border: 1px dashed var(--brand-border);
        }
        
        .empty-state h4 { color: var(--brand-white); }
        .empty-state p { color: var(--brand-gray); }

        /* Badges */
        .badge {
            display: inline-block; padding: 4px 12px;
            border-radius: 100px; font-size: 0.75rem; font-weight: 600;
        }
        .badge-pending { background: rgba(245,158,11,0.2); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.2); color: var(--success); }
        .badge-active { background: rgba(34,197,94,0.2); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.2); color: var(--danger); }
        .badge-draft { background: rgba(148,163,184,0.2); color: var(--brand-gray); }

        /* Buttons */
        .btn {
            padding: 12px 24px; border-radius: 10px;
            font-weight: 600; font-size: 0.95rem;
            cursor: pointer; transition: all 0.3s;
            display: inline-flex; align-items: center; gap: 8px;
            border: none; text-decoration: none;
        }
        .btn-primary { background: var(--brand-dark); color: var(--brand-white); border: 1px solid rgba(255,255,255,0.15); }
        .btn-primary:hover { background: #2d4257; transform: translateY(-2px); }
        .btn-success { background: var(--success); color: #fff; }
        .btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.2); color: var(--brand-white); }
        .btn-outline:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.4); }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; }
        .btn-lg { padding: 16px 32px; font-size: 1.1rem; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }

        .alert { padding: 14px 18px; border-radius: 10px; margin-bottom: 15px; }
        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--success); }

        /* Mobile */
        @media (max-width: 900px) {
            .dashboard-grid { grid-template-columns: 1fr; }
            .sidebar { position: fixed; top: 0; left: -100%; width: 280px; height: 100vh; z-index: 9999; border-radius: 0; transition: left 0.3s; overflow-y: auto; }
            .sidebar.open { left: 0; }
            .sidebar-toggle { display: block; width: 100%; padding: 12px; background: var(--brand-dark); color: white; border: none; border-radius: 10px; font-weight: 600; cursor: pointer; margin-bottom: 20px; }
            .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9998; }
            .sidebar-overlay.open { display: block; }
        }

        @media (max-width: 600px) {
            .stats-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
            .stat-card { padding: 16px; }
            .stat-value { font-size: 1.8rem; }
            .quick-actions { flex-direction: column; }
            .quick-actions .btn { width: 100%; justify-content: center; }
        }

        @media (max-width: 400px) {
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- ========================= HEADER ========================= -->
    <header class="header header-layout2">
        <div class="header-topbar d-none d-sm-block">
            <div class="container-fluid h-100">
                <div class="row align-items-center h-100">
                    <div class="col-12 d-flex align-items-center justify-content-between">
                        <ul class="contact-list d-flex flex-wrap align-items-center list-unstyled mb-0">
                            <li class="d-flex align-items-center">
                                <span>Your trusted partner for secure wealth growth & financial freedom.</span>
                                <a href="/auth/signup" class="btn btn-link btn-white"><span>Start Investing</span><i aria-hidden="true" class="icon-arrow-right2"></i></a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg sticky-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" href="/"><img src="/images/logo.png" class="logo-dark" alt="Montreval Trust Holdings"></a>
                <div class="collapse navbar-collapse" id="mainNavigation">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a href="/" class="nav-item-link">Home</a></li>
                        <li class="nav-item"><a href="/user/dashboard" class="nav-item-link active">Dashboard</a></li>
                        <li class="nav-item"><a href="/auth/logout" class="nav-item-link">Logout</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="dashboard">
        <div class="container">
            <button class="sidebar-toggle d-lg-none" id="sidebarToggle"><i class="fas fa-bars"></i> Menu</button>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <div class="dashboard-grid">
                <!-- Sidebar -->
                <div class="sidebar" id="sidebar">
                    <div class="user-profile">
                        <div class="user-avatar"><i class="fas fa-user-circle"></i></div>
                        <h4><%= user.fullName %></h4>
                        <p><%= user.email %></p>
                    </div>
                    <ul class="sidebar-nav">
                        <li class="active"><a href="/user/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/user/kyc"><i class="fas fa-id-card"></i> Verification</a></li>
                        <li><a href="/user/trusts"><i class="fas fa-shield-haltered"></i> My Trusts</a></li>
                        <li><a href="/user/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                        <li><a href="/user/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </div>

                <!-- Main Content -->
                <div class="content-area">
                    <div class="dashboard-header">
                        <h1>Welcome back, <%= user.fullName.split(' ')[0] %>!</h1>
                        <p>Manage your trusts and digital assets from this dashboard</p>
                    </div>

                    <!-- KYC Status Widget -->
                    <div class="kyc-widget">
                        <div class="kyc-widget-left">
                            <div class="kyc-icon"><i class="fas fa-shield-alt"></i></div>
                            <div class="kyc-info">
                                <h3>Identity Verification</h3>
                                <% if (user.kycStatus === 'not_started') { %>
                                    <p>Complete verification to unlock trust formation and wallet creation.</p>
                                <% } else if (user.kycStatus === 'pending') { %>
                                    <p>Your documents are under review.</p>
                                <% } else if (user.kycStatus === 'approved') { %>
                                    <p>Your identity has been verified.</p>
                                <% } else if (user.kycStatus === 'rejected') { %>
                                    <p>Rejected: <%= user.kycRejectionReason || 'Please resubmit.' %></p>
                                <% } %>
                            </div>
                        </div>
                        <div class="kyc-widget-right">
                            <% if (user.kycStatus === 'not_started') { %>
                                <span class="kyc-status-badge not-started">Not Verified</span>
                                <a href="/user/kyc" class="btn btn-primary" style="margin-left:15px;">Start Verification</a>
                            <% } else if (user.kycStatus === 'pending') { %>
                                <span class="kyc-status-badge pending">In Review</span>
                            <% } else if (user.kycStatus === 'approved') { %>
                                <span class="kyc-status-badge approved">Verified</span>
                            <% } else if (user.kycStatus === 'rejected') { %>
                                <span class="kyc-status-badge rejected">Rejected</span>
                                <a href="/user/kyc?resubmit=1" class="btn btn-primary" style="margin-left:15px;">Resubmit</a>
                            <% } %>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="quick-actions">
                        <a href="/apply" class="btn btn-primary btn-lg"><i class="fas fa-plus-circle"></i> Establish New Trust</a>
                        <% if (locals.success) { %>
                            <div class="alert alert-success"><%= success %></div>
                        <% } %>
                        <% if (locals.hasApprovedTrust) { %>
                            <a href="/user/wallet/create" class="btn btn-success btn-lg"><i class="fas fa-wallet"></i> Create Wallet</a>
                        <% } else { %>
                            <button class="btn btn-outline btn-lg" disabled title="You need an approved trust to create a wallet"><i class="fas fa-lock"></i> Create Wallet</button>
                        <% } %>
                    </div>

                    <!-- Stats Cards -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-clock"></i></div>
                            <div class="stat-value"><%= pendingTrusts %></div>
                            <div class="stat-label">Pending Trusts</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                            <div class="stat-value" style="color:var(--success);"><%= approvedTrusts %></div>
                            <div class="stat-label">Approved Trusts</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-shield-haltered"></i></div>
                            <div class="stat-value"><%= activeTrusts %></div>
                            <div class="stat-label">Active Trusts</div>
                        </div>
                    </div>

                    <!-- Recent Trust Applications -->
                    <div class="recent-section">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
                            <h3>Recent Trust Applications</h3>
                            <a href="/user/trusts" class="btn btn-sm btn-outline">View All <i class="fas fa-arrow-right"></i></a>
                        </div>
                        <% if (locals.recentTrusts && recentTrusts.length > 0) { %>
                            <div class="table-responsive">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Trust Name</th>
                                            <th>Type</th>
                                            <th>Submitted</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentTrusts.forEach(trust => { %>
                                            <tr>
                                                <td><strong><%= trust.trustName %></strong></td>
                                                <td><%= trust.trustType ? trust.trustType.replace(/_/g, ' ') : 'N/A' %></td>
                                                <td><%= trust.submittedAt ? trust.submittedAt.toLocaleDateString() : 'Draft' %></td>
                                                <td><span class="badge badge-<%= trust.status %>"><%= trust.status %></span></td>
                                                <td><a href="/user/trusts/<%= trust._id %>" class="btn btn-sm btn-outline"><i class="fas fa-eye"></i> View</a></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-file-alt" style="font-size:3rem; color:var(--brand-gray); margin-bottom:16px;"></i>
                                <h4>No trust applications yet</h4>
                                <p>Establish your first crypto trust today and secure your digital assets.</p>
                                <a href="/apply" class="btn btn-primary">Establish Trust</a>
                            </div>
                        <% } %>
                    </div>

                    <!-- Wallet Snapshot -->
                    <% if (locals.wallet) { %>
                        <div class="recent-section" style="margin-top:30px;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
                                <h3>Wallet Overview</h3>
                                <a href="/user/wallet" class="btn btn-sm btn-outline">View Full Wallet <i class="fas fa-arrow-right"></i></a>
                            </div>
                            <div class="wallet-snapshot">
                                <div class="wallet-address">
                                    <i class="fas fa-qrcode"></i>
                                    <code><%= wallet.addresses?.btc || 'No address' %></code>
                                </div>
                                <div class="wallet-balance">
                                    <span class="balance-label">Total Balance</span>
                                    <span class="balance-value">$<%= combinedBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) %></span>
                                    <% if (wallet.manualBalance && wallet.manualBalance !== 0) { %>
                                        <small style="color: var(--brand-gray); display:block;">
                                            (includes $<%= wallet.manualBalance.toLocaleString() %> profit)
                                        </small>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================= FOOTER ========================= -->
    <footer class="footer">
        <div class="footer-secondary">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-12">
                        <div class="footer-copyrights my-2">
                            <span class="fz-14">&copy; 2026 Montreval Trust Holdings. All Rights Reserved.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="/assets/js/libraries.js"></script>
    <script src="/assets/js/main.js"></script>
    <script>
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        if (sidebarToggle && sidebar && sidebarOverlay) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                sidebarOverlay.classList.toggle('open');
            });
            sidebarOverlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                sidebarOverlay.classList.remove('open');
            });
        }
    </script>
</body>
</html>