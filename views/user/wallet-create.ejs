<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Wallet | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .card {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 20px;
            padding: 40px;
            backdrop-filter: blur(10px);
        }

        .alert {
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
        }

        .alert-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            color: var(--danger);
        }

        .steps {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 30px;
        }

        .step {
            color: var(--brand-gray);
            font-size: 0.85rem;
            font-weight: 500;
        }

        .step.active {
            color: var(--brand-white);
            font-weight: 600;
        }

        .warning-banner {
            background: rgba(245,158,11,0.08);
            border: 1px solid rgba(245,158,11,0.25);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            gap: 15px;
            margin-bottom: 25px;
        }

        .warning-banner i {
            font-size: 1.8rem;
            color: var(--warning);
            flex-shrink: 0;
        }

        .warning-banner strong {
            color: var(--brand-white);
            display: block;
            margin-bottom: 4px;
        }

        .warning-banner p {
            color: var(--brand-gray);
            font-size: 0.85rem;
            margin: 0;
        }

        h2 {
            color: var(--brand-white);
            font-size: 1.3rem;
            margin: 25px 0 15px;
        }

        .phrase-container {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 25px;
            margin-bottom: 20px;
        }

        .phrase-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        .phrase-word {
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--brand-border);
            border-radius: 8px;
            padding: 10px 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .word-index {
            color: var(--brand-gray);
            font-size: 0.75rem;
            min-width: 20px;
        }

        .word-value {
            font-family: 'Courier New', monospace;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--brand-white);
        }

        .phrase-actions {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--brand-border);
            color: var(--brand-white);
        }

        .btn-outline:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.25);
        }

        .btn-success {
            background: var(--success);
            color: #fff;
        }

        .btn-success:hover { background: #16a34a; }

        .btn-success:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .btn-primary {
            background: var(--brand-dark);
            color: var(--brand-white);
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-lg { padding: 14px 28px; font-size: 1rem; }

        .detail-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        .detail-table th {
            text-align: left;
            padding: 10px 12px;
            color: var(--brand-gray);
            font-weight: 500;
            font-size: 0.8rem;
            text-transform: uppercase;
            width: 80px;
            border-bottom: 1px solid var(--brand-border);
        }

        .detail-table td {
            padding: 10px 12px;
            border-bottom: 1px solid var(--brand-border);
        }

        .detail-table code {
            color: var(--brand-white);
            font-family: monospace;
            font-size: 0.85rem;
            word-break: break-all;
        }

        .btn-icon {
            background: none;
            border: none;
            color: var(--brand-gray);
            cursor: pointer;
            padding: 4px 8px;
            font-size: 0.8rem;
        }

        .btn-icon:hover { color: var(--brand-white); }

        .confirmation-section {
            margin: 25px 0;
        }

        .checkbox-label {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 16px;
            cursor: pointer;
            color: var(--brand-gray);
            font-size: 0.9rem;
        }

        .checkbox-label input {
            margin-top: 3px;
            accent-color: var(--brand-white);
        }

        .form-actions {
            text-align: center;
        }

        .loading-spinner {
            width: 50px; height: 50px;
            border: 3px solid var(--brand-border);
            border-top-color: var(--brand-white);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .card { padding: 20px; }
            .phrase-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="card">
            <% if (locals.error) { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
                <div style="text-align:center; margin-top:25px;">
                    <a href="/user/dashboard" class="btn btn-primary">Return to Dashboard</a>
                </div>
            <% } else if (locals.phrase) { %>
                <div class="steps">
                    <span class="step active">1. Generate</span>
                    <span class="step active">2. Secure Phrase</span>
                    <span class="step">3. Confirm</span>
                </div>

                <div class="warning-banner">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <strong>This is the ONLY time you will see this phrase.</strong>
                        <p>We do not store your recovery phrase. If you lose it, you will permanently lose access to your wallet and all funds.</p>
                    </div>
                </div>

                <h2>Your Recovery Phrase</h2>

                <div class="phrase-container">
                    <% const words = phrase.split(' '); %>
                    <div class="phrase-grid">
                        <% words.forEach((word, index) => { %>
                            <div class="phrase-word">
                                <span class="word-index"><%= index + 1 %></span>
                                <span class="word-value"><%= word %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="phrase-actions">
                    <button class="btn btn-outline" onclick="copyText('<%= phrase %>')">
                        <i class="fas fa-copy"></i> Copy to Clipboard
                    </button>
                    <button class="btn btn-outline" id="downloadBtn">
                        <i class="fas fa-download"></i> Download as Text
                    </button>
                </div>

                <table class="detail-table">
                    <tr><th>BTC</th><td><code><%= addresses.btc %></code> <button class="btn-icon" onclick="copyText('<%= addresses.btc %>')"><i class="fas fa-copy"></i></button></td></tr>
                    <tr><th>ETH</th><td><code><%= addresses.eth %></code> <button class="btn-icon" onclick="copyText('<%= addresses.eth %>')"><i class="fas fa-copy"></i></button></td></tr>
                    <tr><th>USDT</th><td><code><%= addresses.usdt %></code> <button class="btn-icon" onclick="copyText('<%= addresses.usdt %>')"><i class="fas fa-copy"></i></button></td></tr>
                    <tr><th>XRP</th><td><code><%= addresses.xrp %></code> <button class="btn-icon" onclick="copyText('<%= addresses.xrp %>')"><i class="fas fa-copy"></i></button></td></tr>
                    <tr><th>BNB</th><td><code><%= addresses.bnb %></code> <button class="btn-icon" onclick="copyText('<%= addresses.bnb %>')"><i class="fas fa-copy"></i></button></td></tr>
                    <tr><th>Linked Trust</th><td><%= trustName %></td></tr>
                </table>

                <form action="/user/wallet/confirm" method="POST" onsubmit="return validateConfirmation()">
                    <input type="hidden" name="walletId" value="<%= walletId %>">
                    <input type="hidden" name="viewToken" value="<%= viewToken %>">
                    
                    <div class="confirmation-section">
                        <label class="checkbox-label">
                            <input type="checkbox" id="confirmSaved" required>
                            <span>I have securely stored my recovery phrase in a safe place.</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" id="confirmUnderstand" required>
                            <span>I understand that if I lose this phrase, I will lose access to my wallet forever.</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" id="confirmNoScreenshot" required>
                            <span>I have not taken any screenshots or photos of this phrase.</span>
                        </label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-success btn-lg" id="confirmBtn" disabled>
                            <i class="fas fa-check-circle"></i> I Have Saved My Phrase – Continue
                        </button>
                    </div>
                </form>
            <% } else { %>
                <div style="text-align:center; padding:40px;">
                    <div class="loading-spinner"></div>
                    <p style="color:var(--brand-gray);">Generating your secure wallet...</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function copyText(text) {
            navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard'));
        }

        const checkboxes = document.querySelectorAll('.confirmation-section input[type="checkbox"]');
        const confirmBtn = document.getElementById('confirmBtn');

        if (checkboxes.length && confirmBtn) {
            checkboxes.forEach(cb => {
                cb.addEventListener('change', () => {
                    confirmBtn.disabled = !Array.from(checkboxes).every(c => c.checked);
                });
            });
        }

        function validateConfirmation() {
            return Array.from(checkboxes).every(c => c.checked);
        }
    </script>
</body>
</html>