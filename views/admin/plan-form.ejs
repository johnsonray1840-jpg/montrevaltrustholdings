<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: var(--bg-dark); font-family: 'DM Sans', sans-serif; color: #e2e8f0; min-height: 100vh; }

        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px; height: 64px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .admin-header .logo { color: var(--brand-white); font-weight: 700; font-size: 1.1rem; text-decoration: none; display: flex; align-items: center; gap: 8px; }

        .admin-layout { display: flex; min-height: calc(100vh - 64px); }

        .admin-sidebar {
            width: 250px; background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border); padding: 20px 0; flex-shrink: 0;
        }
        .admin-sidebar a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: var(--brand-gray);
            text-decoration: none; font-size: 0.9rem;
            border-left: 3px solid transparent; transition: all 0.2s;
        }
        .admin-sidebar a:hover { background: rgba(255,255,255,0.03); color: var(--brand-white); }
        .admin-sidebar a.active { background: rgba(255,255,255,0.05); color: var(--brand-white); border-left-color: var(--brand-white); font-weight: 600; }
        .admin-sidebar a i { width: 20px; text-align: center; }

        .admin-main { flex: 1; padding: 30px; overflow-x: auto; }

        .back-link { color: var(--brand-gray); text-decoration: none; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 5px; }
        .back-link:hover { color: var(--brand-white); }
        h1 { font-size: 1.6rem; color: var(--brand-white); margin-bottom: 20px; }

        .alert { padding: 14px 18px; border-radius: 10px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; }
        .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--danger); }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; margin-bottom: 6px; color: var(--brand-gray); font-size: 0.85rem; font-weight: 500; }

        .form-control {
            width: 100%; padding: 11px 14px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--brand-border);
            border-radius: 10px; color: var(--brand-white); font-size: 0.9rem;
            font-family: inherit;
        }
        .form-control:focus { outline: none; border-color: rgba(255,255,255,0.3); }
        textarea.form-control { resize: vertical; }
        small { color: var(--brand-gray); font-size: 0.75rem; display: block; margin-top: 4px; }

        .form-row { display: flex; gap: 30px; flex-wrap: wrap; margin-bottom: 15px; }

        .checkbox-label {
            display: flex; align-items: center; gap: 10px;
            color: var(--brand-gray); font-size: 0.9rem; cursor: pointer;
        }
        .checkbox-label input { accent-color: var(--brand-white); }

        .btn {
            padding: 10px 20px; border-radius: 10px; font-weight: 600;
            font-size: 0.9rem; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
            transition: all 0.2s; border: none;
        }
        .btn-primary { background: var(--brand-dark); color: var(--brand-white); border: 1px solid rgba(255,255,255,0.12); }
        .btn-primary:hover { background: #2d4257; }
        .btn-outline { background: transparent; border: 1px solid var(--brand-border); color: var(--brand-white); }
        .btn-outline:hover { background: rgba(255,255,255,0.05); }
        .btn-lg { padding: 14px 28px; font-size: 1rem; }

        @media (max-width: 768px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--brand-border); }
            .admin-main { padding: 20px 15px; }
        }
    </style>
</head>
<body>

    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i> MONTREVAL
        </a>
        <a href="/auth/logout" style="color:var(--brand-gray);text-decoration:none;font-size:0.85rem;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </header>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a>
                <a href="/admin/plans" class="active"><i class="fas fa-box"></i> Plans</a>
                <a href="/admin/trusts"><i class="fas fa-shield-haltered"></i> Trust Applications</a>
                <a href="/admin/withdrawals"><i class="fas fa-money-bill-wave"></i> Withdrawals</a>
                <a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a>
                <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
            </nav>
        </aside>

        <main class="admin-main">
            <a href="/admin/plans" class="back-link"><i class="fas fa-arrow-left"></i> Back to Plans</a>
            <h1><%= title %></h1>

            <% if (locals.error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

            <form action="<%= formAction %>" method="POST">
                <div class="form-group">
                    <label>Plan Name *</label>
                    <input type="text" name="name" class="form-control" value="<%= plan ? plan.name : '' %>" placeholder="e.g., Basic, Pro, Enterprise" required>
                </div>
                <div class="form-group">
                    <label>Price (USD) *</label>
                    <input type="number" name="price" class="form-control" value="<%= plan ? plan.price : '49' %>" min="0" step="0.01" required>
                </div>
                <div class="form-group">
                    <label>Processing Time *</label>
                    <input type="text" name="processingTime" class="form-control" value="<%= plan ? plan.processingTime : 'Standard 7-10 day processing' %>" required>
                    <small>Example: "Fastest 1-day processing" or "Standard 7-10 day processing"</small>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" class="form-control" rows="3"><%= plan ? plan.description : '' %></textarea>
                </div>
                <div class="form-group">
                    <label>Features * (One per line)</label>
                    <textarea name="features" class="form-control" rows="8" required><%= plan ? plan.features.join('\n') : '100% accuracy guarantee\nName availability check\nArticles of Organization' %></textarea>
                    <small>Enter each feature on a new line</small>
                </div>
                <div class="form-row">
                    <label class="checkbox-label">
                        <input type="checkbox" name="recommended" <%= plan && plan.recommended ? 'checked' : '' %>>
                        Mark as Recommended (Featured)
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="isActive" <%= plan && plan.isActive !== false ? 'checked' : '' %>>
                        Active (Visible to customers)
                    </label>
                </div>
                <div class="form-group" style="margin-top:20px;">
                    <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> <%= submitText %></button>
                    <a href="/admin/plans" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </main>
    </div>

</body>
</html>