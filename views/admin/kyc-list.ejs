<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KYC Verification | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-header .logo {
            color: var(--brand-white);
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .admin-layout {
            display: flex;
            min-height: calc(100vh - 64px);
        }

        .admin-sidebar {
            width: 250px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border);
            padding: 20px 0;
            flex-shrink: 0;
        }

        .admin-sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.9rem;
            border-left: 3px solid transparent;
            transition: all 0.2s;
        }

        .admin-sidebar a:hover { background: rgba(255,255,255,0.03); color: var(--brand-white); }
        .admin-sidebar a.active { background: rgba(255,255,255,0.05); color: var(--brand-white); border-left-color: var(--brand-white); font-weight: 600; }
        .admin-sidebar a i { width: 20px; text-align: center; }

        .admin-main {
            flex: 1;
            padding: 30px;
            overflow-x: auto;
        }

        .admin-main h1 {
            font-size: 1.8rem;
            color: var(--brand-white);
            margin-bottom: 20px;
        }

        .alert {
            padding: 14px 18px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.3);
            color: var(--success);
        }

        .filter-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .filter-chip {
            padding: 10px 20px;
            border-radius: 100px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--brand-border);
            color: var(--brand-gray);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-chip:hover {
            border-color: rgba(255,255,255,0.25);
            color: var(--brand-white);
        }

        .filter-chip.active {
            background: var(--brand-dark);
            border-color: var(--brand-dark);
            color: var(--brand-white);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 12px;
            overflow: hidden;
        }

        .data-table th {
            text-align: left;
            padding: 14px 16px;
            background: rgba(255,255,255,0.03);
            color: var(--brand-gray);
            font-weight: 500;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--brand-border);
        }

        .data-table td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--brand-border);
            color: #e2e8f0;
            font-size: 0.9rem;
        }

        .data-table tr:last-child td { border-bottom: none; }
        .data-table small { color: var(--brand-gray); }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .badge-pending { background: rgba(245,158,11,0.15); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.15); color: var(--danger); }
        .badge-not_started { background: rgba(148,163,184,0.15); color: var(--brand-gray); }

        .btn {
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            border: 1px solid var(--brand-border);
            color: var(--brand-white);
            background: transparent;
        }

        .btn:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); }

        @media (max-width: 768px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--brand-border); }
            .admin-main { padding: 20px 15px; }
        }
    </style>
</head>
<body>

    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i> MONTREVAL
        </a>
        <a href="/auth/logout" style="color:var(--brand-gray);text-decoration:none;font-size:0.85rem;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </header>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin/kyc" class="active"><i class="fas fa-id-card"></i> KYC Verification</a>
                <a href="/admin/plans"><i class="fas fa-box"></i> Plans</a>
                <a href="/admin/trusts"><i class="fas fa-file-alt"></i> Applications</a>
                <a href="/admin/trusts"><i class="fas fa-shield-haltered"></i> Trust Management</a>
                <a href="/admin/withdrawals"><i class="fas fa-money-bill-wave"></i> Withdrawals</a>
                <a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a>
                <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
            </nav>
        </aside>

        <main class="admin-main">
            <h1>KYC Verification Requests</h1>

            <% if (locals.success) { %>
                <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
            <% } %>

            <div class="filter-bar">
                <a href="/admin/kyc?status=pending" class="filter-chip <%= filter==='pending' ? 'active' : '' %>">
                    <i class="fas fa-clock"></i> Pending
                </a>
                <a href="/admin/kyc?status=approved" class="filter-chip <%= filter==='approved' ? 'active' : '' %>">
                    <i class="fas fa-check-circle"></i> Approved
                </a>
                <a href="/admin/kyc?status=rejected" class="filter-chip <%= filter==='rejected' ? 'active' : '' %>">
                    <i class="fas fa-times-circle"></i> Rejected
                </a>
                <a href="/admin/kyc?status=all" class="filter-chip <%= filter==='all' ? 'active' : '' %>">
                    <i class="fas fa-list"></i> All
                </a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Submitted</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users.length) { %>
                        <% users.forEach(u => { %>
                            <tr>
                                <td>
                                    <%= u.fullName %><br>
                                    <small><%= u.email %></small>
                                </td>
                                <td><%= u.kycSubmittedAt ? u.kycSubmittedAt.toLocaleDateString() : '—' %></td>
                                <td><span class="badge badge-<%= u.kycStatus %>"><%= u.kycStatus.replace(/_/g, ' ') %></span></td>
                                <td><a href="/admin/kyc/<%= u._id %>" class="btn">Review</a></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align:center;padding:40px;color:var(--brand-gray);">No KYC requests found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>

</body>
</html>