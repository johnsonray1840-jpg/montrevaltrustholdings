<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KYC Detail | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.9rem;
            margin-bottom: 25px;
            transition: color 0.2s;
        }

        .back-link:hover { color: var(--brand-white); }

        /* Profile header */
        .profile-header {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .profile-header h1 {
            font-size: 1.6rem;
            color: var(--brand-white);
            margin-bottom: 4px;
        }

        .profile-header .email {
            color: var(--brand-gray);
            font-size: 0.9rem;
        }

        .badge {
            display: inline-block;
            padding: 8px 18px;
            border-radius: 100px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .badge-pending { background: rgba(245,158,11,0.15); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.15); color: var(--danger); }
        .badge-not_started { background: rgba(148,163,184,0.15); color: var(--brand-gray); }

        /* Data grid */
        .data-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        .data-card {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 24px;
        }

        .data-card h3 {
            color: var(--brand-white);
            font-size: 1rem;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .data-card h3 i { color: var(--brand-white); }

        .data-table { width: 100%; }

        .data-table th {
            text-align: left;
            padding: 10px 0;
            color: var(--brand-gray);
            width: 40%;
            font-weight: 500;
            font-size: 0.85rem;
        }

        .data-table td {
            padding: 10px 0;
            color: var(--brand-white);
            font-size: 0.9rem;
        }

        /* Document grid */
        .document-card {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 25px;
        }

        .document-card h3 {
            color: var(--brand-white);
            font-size: 1rem;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .document-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 16px;
        }

        .doc-item {
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--brand-border);
            border-radius: 10px;
            overflow: hidden;
        }

        .doc-item img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            display: block;
        }

        .doc-item embed {
            width: 100%;
            height: 220px;
            display: block;
        }

        .doc-label {
            padding: 12px;
            text-align: center;
            font-size: 0.85rem;
            color: var(--brand-white);
            font-weight: 500;
        }

        .doc-label a {
            color: var(--brand-white);
            margin-left: 6px;
            font-size: 0.75rem;
        }

        .doc-empty {
            padding: 60px 20px;
            text-align: center;
            color: var(--brand-gray);
            font-size: 0.9rem;
        }

        /* Buttons */
        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-success {
            background: var(--success);
            color: #fff;
        }

        .btn-success:hover { background: #16a34a; }

        .btn-danger {
            background: rgba(239,68,68,0.15);
            color: var(--danger);
            border: 1px solid rgba(239,68,68,0.3);
        }

        .btn-danger:hover { background: rgba(239,68,68,0.25); }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--brand-border);
            color: var(--brand-white);
        }

        .btn-outline:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.25);
        }

        .btn-lg { padding: 14px 28px; font-size: 1rem; }

        .action-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* Modal */
        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-content {
            background: #1a1f2e;
            border: 1px solid var(--brand-border);
            border-radius: 16px;
            padding: 30px;
            max-width: 480px;
            width: 90%;
        }

        .modal-content h3 {
            color: var(--brand-white);
            margin-bottom: 15px;
        }

        .modal-content textarea {
            width: 100%;
            padding: 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--brand-border);
            border-radius: 10px;
            color: var(--brand-white);
            resize: vertical;
            font-family: inherit;
            font-size: 0.9rem;
        }

        .modal-content textarea:focus {
            outline: none;
            border-color: rgba(255,255,255,0.3);
        }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            justify-content: flex-end;
        }

        @media (max-width: 768px) {
            .data-grid { grid-template-columns: 1fr; }
            .profile-header { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>

    <div class="container">
        <a href="/admin/kyc" class="back-link"><i class="fas fa-arrow-left"></i> Back to KYC List</a>
        
        <!-- Profile Header -->
        <div class="profile-header">
            <div>
                <h1><%= user.fullName %></h1>
                <p class="email"><%= user.email %></p>
            </div>
            <span class="badge badge-<%= user.kycStatus %>"><%= user.kycStatus.replace(/_/g, ' ') %></span>
        </div>

        <!-- Data Grid -->
        <div class="data-grid">
            <div class="data-card">
                <h3><i class="fas fa-user"></i> Personal Information</h3>
                <table class="data-table">
                    <tr><th>Full Name</th><td><%= user.fullName %></td></tr>
                    <tr><th>Date of Birth</th><td><%= user.kycData?.dateOfBirth?.toLocaleDateString() || '—' %></td></tr>
                    <tr><th>SSN (last 4)</th><td><%= user.kycData?.ssnLast4 || '—' %></td></tr>
                </table>
            </div>
            <div class="data-card">
                <h3><i class="fas fa-id-card"></i> ID Details</h3>
                <table class="data-table">
                    <tr><th>ID Type</th><td><%= user.kycData?.idType?.replace(/_/g, ' ').toUpperCase() || '—' %></td></tr>
                    <tr><th>ID Number</th><td><%= user.kycData?.idNumber || '—' %></td></tr>
                    <tr><th>Address</th><td><%= user.kycData?.addressDetails?.street %>, <%= user.kycData?.addressDetails?.city %>, <%= user.kycData?.addressDetails?.state %> <%= user.kycData?.addressDetails?.zipCode %></td></tr>
                </table>
            </div>
        </div>

        <!-- Documents -->
        <div class="document-card">
            <h3><i class="fas fa-images"></i> Uploaded Documents</h3>
            <div class="document-grid">
                <div class="doc-item">
                    <% if (user.kycData?.idFrontImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/idFrontImage" alt="ID Front">
                        <div class="doc-label">ID Front <a href="/admin/kyc/document/<%= user._id %>/idFrontImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %>
                        <div class="doc-empty">Not uploaded</div>
                    <% } %>
                </div>
                <div class="doc-item">
                    <% if (user.kycData?.idBackImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/idBackImage" alt="ID Back">
                        <div class="doc-label">ID Back <a href="/admin/kyc/document/<%= user._id %>/idBackImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %>
                        <div class="doc-empty">Not uploaded</div>
                    <% } %>
                </div>
                <div class="doc-item">
                    <% if (user.kycData?.selfieImage) { %>
                        <img src="/admin/kyc/document/<%= user._id %>/selfieImage" alt="Selfie">
                        <div class="doc-label">Selfie with ID <a href="/admin/kyc/document/<%= user._id %>/selfieImage" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %>
                        <div class="doc-empty">Not uploaded</div>
                    <% } %>
                </div>
                <div class="doc-item">
                    <% if (user.kycData?.addressDocument) { %>
                        <% if (user.kycData.addressDocument.filePath.endsWith('.pdf')) { %>
                            <embed src="/admin/kyc/document/<%= user._id %>/addressDocument" width="100%" height="220px">
                        <% } else { %>
                            <img src="/admin/kyc/document/<%= user._id %>/addressDocument" alt="Address Proof">
                        <% } %>
                        <div class="doc-label">Address Proof <a href="/admin/kyc/document/<%= user._id %>/addressDocument" target="_blank"><i class="fas fa-external-link-alt"></i></a></div>
                    <% } else { %>
                        <div class="doc-empty">Not uploaded</div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <% if (user.kycStatus === 'pending') { %>
            <div class="action-bar">
                <form action="/admin/kyc/<%= user._id %>/approve" method="POST">
                    <button type="submit" class="btn btn-success btn-lg"><i class="fas fa-check-circle"></i> Approve KYC</button>
                </form>
                <button id="showRejectBtn" class="btn btn-danger btn-lg"><i class="fas fa-times-circle"></i> Reject KYC</button>
                <form action="/admin/kyc/<%= user._id %>/delete" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-outline btn-lg"><i class="fas fa-trash"></i> Delete KYC</button>
                </form>
            </div>

            <!-- Reject Modal -->
            <div id="rejectModal" class="modal" style="display:none;">
                <div class="modal-content">
                    <h3>Reject KYC Submission</h3>
                    <form action="/admin/kyc/<%= user._id %>/reject" method="POST">
                        <textarea name="reason" placeholder="Reason for rejection (sent to user)" rows="4" required></textarea>
                        <div class="modal-actions">
                            <button type="submit" class="btn btn-danger">Confirm Reject</button>
                            <button type="button" id="hideRejectBtn" class="btn btn-outline">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        <% } %>

        <% if (user.kycStatus !== 'pending') { %>
            <div class="action-bar">
                <form action="/admin/kyc/<%= user._id %>/delete" method="POST" onsubmit="return confirm('Delete this KYC? User will need to resubmit.');">
                    <button type="submit" class="btn btn-outline btn-lg"><i class="fas fa-trash"></i> Delete KYC</button>
                </form>
            </div>
        <% } %>
    </div>

    <script>
        const showBtn = document.getElementById('showRejectBtn');
        const hideBtn = document.getElementById('hideRejectBtn');
        const modal = document.getElementById('rejectModal');

        if (showBtn && modal) {
            showBtn.addEventListener('click', () => modal.style.display = 'flex');
        }
        if (hideBtn && modal) {
            hideBtn.addEventListener('click', () => modal.style.display = 'none');
        }
    </script>
</body>
</html>