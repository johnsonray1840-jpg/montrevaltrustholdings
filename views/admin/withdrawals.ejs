<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Withdrawals | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-header .logo {
            color: var(--brand-white);
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .admin-layout { display: flex; min-height: calc(100vh - 64px); }

        .admin-sidebar {
            width: 250px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border);
            padding: 20px 0;
            flex-shrink: 0;
        }

        .admin-sidebar a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: var(--brand-gray);
            text-decoration: none; font-size: 0.9rem;
            border-left: 3px solid transparent; transition: all 0.2s;
        }

        .admin-sidebar a:hover { background: rgba(255,255,255,0.03); color: var(--brand-white); }
        .admin-sidebar a.active { background: rgba(255,255,255,0.05); color: var(--brand-white); border-left-color: var(--brand-white); font-weight: 600; }
        .admin-sidebar a i { width: 20px; text-align: center; }

        .admin-main { flex: 1; padding: 30px; overflow-x: auto; }

        .admin-main h1 { font-size: 1.8rem; color: var(--brand-white); margin-bottom: 20px; }

        .alert {
            padding: 14px 18px; border-radius: 10px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px; font-size: 0.9rem;
        }

        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--success); }
        .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--danger); }

        .filter-tabs {
            display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;
        }

        .filter-tab {
            padding: 8px 18px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--brand-border);
            border-radius: 100px;
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .filter-tab:hover { border-color: rgba(255,255,255,0.25); color: var(--brand-white); }
        .filter-tab.active { background: var(--brand-dark); color: var(--brand-white); border-color: var(--brand-dark); }

        .data-table {
            width: 100%; border-collapse: collapse;
            background: var(--brand-bg); border: 1px solid var(--brand-border);
            border-radius: 12px; overflow: hidden;
        }

        .data-table th {
            text-align: left; padding: 14px 16px;
            background: rgba(255,255,255,0.03); color: var(--brand-gray);
            font-weight: 500; font-size: 0.8rem; text-transform: uppercase;
            letter-spacing: 0.5px; border-bottom: 1px solid var(--brand-border);
        }

        .data-table td {
            padding: 14px 16px; border-bottom: 1px solid var(--brand-border);
            color: #e2e8f0; font-size: 0.9rem;
        }

        .data-table tr:last-child td { border-bottom: none; }
        .data-table small { color: var(--brand-gray); }
        code { color: var(--brand-white); }

        .badge {
            display: inline-block; padding: 4px 10px;
            border-radius: 100px; font-size: 0.7rem; font-weight: 600;
            text-transform: capitalize;
        }

        .badge-pending { background: rgba(245,158,11,0.15); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.15); color: var(--danger); }

        .btn {
            padding: 8px 16px; border-radius: 8px; font-weight: 600;
            font-size: 0.8rem; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; gap: 6px;
            transition: all 0.2s; border: none;
        }

        .btn-success { background: var(--success); color: #fff; }
        .btn-success:hover { background: #16a34a; }

        .btn-danger { background: rgba(239,68,68,0.15); color: var(--danger); border: 1px solid rgba(239,68,68,0.3); }
        .btn-danger:hover { background: rgba(239,68,68,0.25); }

        .btn-outline { background: transparent; border: 1px solid var(--brand-border); color: var(--brand-white); }

        .action-buttons { display: flex; gap: 6px; }

        .modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); display: none;
            align-items: center; justify-content: center; z-index: 1000;
        }

        .modal-content {
            background: #1a1f2e; border: 1px solid var(--brand-border);
            border-radius: 16px; padding: 30px; max-width: 450px; width: 90%;
        }

        .modal-content h3 { color: var(--brand-white); margin-bottom: 15px; }

        .modal-content textarea {
            width: 100%; padding: 12px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--brand-border);
            border-radius: 10px; color: var(--brand-white); resize: vertical;
            font-family: inherit; font-size: 0.9rem; margin-bottom: 15px;
        }

        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; }

        @media (max-width: 768px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--brand-border); }
            .admin-main { padding: 20px 15px; }
        }
    </style>
</head>
<body>

    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i> MONTREVAL
        </a>
        <a href="/auth/logout" style="color:var(--brand-gray);text-decoration:none;font-size:0.85rem;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </header>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a>
                <a href="/admin/plans"><i class="fas fa-box"></i> Plans</a>
                <a href="/admin/trusts"><i class="fas fa-file-alt"></i>Trust Applications</a>
                <!-- <a href="/admin/trusts"><i class="fas fa-shield-haltered"></i> Trust Management</a> -->
                <a href="/admin/withdrawals" class="active"><i class="fas fa-money-bill-wave"></i> Withdrawals</a>
                <a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a>
                <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
            </nav>
        </aside>

        <main class="admin-main">
            <h1>Withdrawal Requests</h1>

            <% if (locals.success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
            <% if (locals.error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

            <div class="filter-tabs">
                <a href="/admin/withdrawals?status=pending" class="filter-tab <%= filter==='pending'?'active':'' %>">Pending</a>
                <a href="/admin/withdrawals?status=approved" class="filter-tab <%= filter==='approved'?'active':'' %>">Approved</a>
                <a href="/admin/withdrawals?status=rejected" class="filter-tab <%= filter==='rejected'?'active':'' %>">Rejected</a>
                <a href="/admin/withdrawals?status=all" class="filter-tab <%= filter==='all'?'active':'' %>">All</a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Chain</th>
                        <th>Amount</th>
                        <th>Destination</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (withdrawals && withdrawals.length > 0) { %>
                        <% withdrawals.forEach(w => { %>
                            <tr>
                                <td>
                                    <%= w.userId?.fullName || 'N/A' %><br>
                                    <small><%= w.userId?.email || '' %></small>
                                </td>
                                <td><%= w.chain?.toUpperCase() || 'N/A' %></td>
                                <td>$<%= w.amount?.toLocaleString() || '0' %></td>
                                <td><code><%= w.toAddress?.substring(0,10) || '' %>...</code></td>
                                <td><span class="badge badge-<%= w.status %>"><%= w.status %></span></td>
                                <td>
                                    <% if (w.status === 'pending') { %>
                                        <div class="action-buttons">
                                            <form action="/admin/withdrawals/<%= w._id %>/approve" method="POST" style="display:inline;">
                                                <button class="btn btn-success">Approve</button>
                                            </form>
                                            <button class="btn btn-danger show-reject-modal"
                                                    data-id="<%= w._id %>"
                                                    data-chain="<%= w.chain %>"
                                                    data-amount="<%= w.amount %>">Reject</button>
                                        </div>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align:center;padding:40px;color:var(--brand-gray);">No withdrawal requests found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </main>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="modal">
        <div class="modal-content">
            <h3>Reject Withdrawal</h3>
            <form id="rejectForm" method="POST">
                <textarea name="reason" placeholder="Reason for rejection" rows="3" required></textarea>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-outline close-modal-btn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('rejectModal');
        const rejectForm = document.getElementById('rejectForm');

        document.querySelectorAll('.show-reject-modal').forEach(btn => {
            btn.addEventListener('click', function() {
                rejectForm.action = '/admin/withdrawals/' + this.dataset.id + '/reject';
                modal.style.display = 'flex';
            });
        });

        document.querySelectorAll('.close-modal-btn').forEach(btn => {
            btn.addEventListener('click', () => modal.style.display = 'none');
        });

        modal.addEventListener('click', function(e) {
            if (e.target === modal) modal.style.display = 'none';
        });
    </script>
</body>
</html>