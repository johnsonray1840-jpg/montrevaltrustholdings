<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        /* Header */
        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .admin-header .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--brand-white);
            font-weight: 700;
            font-size: 1.1rem;
        }

        .admin-header .logo i {
            font-size: 1.3rem;
        }

        .admin-badge {
            background: rgba(255,255,255,0.12);
            color: var(--brand-white);
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .admin-header .user-menu {
            display: flex;
            align-items: center;
            gap: 15px;
            color: var(--brand-white);
        }

        .admin-header .user-menu a {
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.85rem;
        }

        .admin-header .user-menu a:hover {
            color: var(--brand-white);
        }

        /* Layout */
        .admin-layout {
            display: flex;
            min-height: calc(100vh - 64px);
        }

        /* Sidebar */
        .admin-sidebar {
            width: 250px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border);
            padding: 20px 0;
            flex-shrink: 0;
        }

        .admin-sidebar nav {
            display: flex;
            flex-direction: column;
        }

        .admin-sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .admin-sidebar a:hover {
            background: rgba(255,255,255,0.03);
            color: var(--brand-white);
        }

        .admin-sidebar a.active {
            background: rgba(255,255,255,0.05);
            color: var(--brand-white);
            border-left-color: var(--brand-white);
            font-weight: 600;
        }

        .admin-sidebar a i {
            width: 20px;
            text-align: center;
        }

        /* Main */
        .admin-main {
            flex: 1;
            padding: 30px;
            overflow-x: auto;
        }

        .admin-main h1 {
            font-size: 1.8rem;
            color: var(--brand-white);
            margin-bottom: 5px;
        }

        .admin-main .subtitle {
            color: var(--brand-gray);
            margin-bottom: 30px;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 16px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 20px;
        }

        .stat-card .stat-icon {
            width: 42px; height: 42px;
            background: var(--brand-dark);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 12px;
        }

        .stat-card .stat-icon i {
            font-size: 1.2rem;
            color: var(--brand-white);
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--brand-white);
        }

        .stat-label {
            color: var(--brand-gray);
            font-size: 0.8rem;
            margin-top: 2px;
        }

        /* Quick actions */
        .quick-actions {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 30px;
        }

        .quick-actions h3 {
            color: var(--brand-white);
            margin-bottom: 15px;
            font-size: 1rem;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            border: none;
        }

        .btn-primary {
            background: var(--brand-dark);
            color: var(--brand-white);
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-primary:hover {
            background: #2d4257;
            color: #fff;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--brand-border);
            color: var(--brand-white);
        }

        .btn-outline:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.25);
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.8rem;
        }

        /* Table */
        .recent-section h3 {
            color: var(--brand-white);
            margin-bottom: 15px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 12px;
            overflow: hidden;
        }

        .data-table th {
            text-align: left;
            padding: 14px 16px;
            background: rgba(255,255,255,0.03);
            color: var(--brand-gray);
            font-weight: 500;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--brand-border);
        }

        .data-table td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--brand-border);
            color: #e2e8f0;
            font-size: 0.9rem;
        }

        .data-table tr:last-child td {
            border-bottom: none;
        }

        .data-table small {
            color: var(--brand-gray);
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .badge-pending {
            background: rgba(245,158,11,0.15);
            color: var(--warning);
        }

        .badge-approved {
            background: rgba(34,197,94,0.15);
            color: var(--success);
        }

        .badge-active {
            background: rgba(34,197,94,0.15);
            color: var(--success);
        }

        .badge-rejected {
            background: rgba(239,68,68,0.15);
            color: var(--danger);
        }

        .badge-draft {
            background: rgba(148,163,184,0.15);
            color: var(--brand-gray);
        }

        .badge-under_review {
            background: rgba(59,130,246,0.15);
            color: #60a5fa;
        }

        .view-all {
            margin-top: 15px;
        }

        .view-all a {
            color: var(--brand-white);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .view-all a:hover {
            text-decoration: underline;
        }

        .no-data {
            color: var(--brand-gray);
            padding: 40px;
            text-align: center;
            background: var(--brand-bg);
            border-radius: 12px;
            border: 1px dashed var(--brand-border);
        }

        @media (max-width: 768px) {
            .admin-layout {
                flex-direction: column;
            }

            .admin-sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid var(--brand-border);
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i>
            MONTREVAL <span class="admin-badge">Admin</span>
        </a>
        <div class="user-menu">
            <span><i class="fas fa-user-shield"></i> <%= user.fullName %></span>
            <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </header>

    <div class="admin-layout">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard" class="active">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/admin/plans">
                    <i class="fas fa-box"></i> Plans
                </a>
                <a href="/admin/kyc">
                    <i class="fas fa-id-card"></i> KYC Verification
                </a>
                <a href="/admin/trusts">
                    <i class="fas fa-file-alt"></i>Trust Applications
                </a>
                <!-- <a href="/admin/trusts">
                    <i class="fas fa-shield-haltered"></i> Trust Management
                </a> -->
                <a href="/admin/withdrawals">
                    <i class="fas fa-money-bill-wave"></i> Withdrawals
                </a>
                <a href="/admin/wallet-pool">
                    <i class="fas fa-wallet"></i> Wallet Pool
                </a>
                <a href="/admin/users">
                    <i class="fas fa-users"></i> Users
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <h1>Admin Dashboard</h1>
            <p class="subtitle">Overview of your Montreval Trust Holdings platform</p>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <div class="stat-value"><%= stats.totalUsers %></div>
                    <div class="stat-label">Total Users</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
                    <div class="stat-value"><%= stats.totalApplications %></div>
                    <div class="stat-label">Total Applications</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-clock"></i></div>
                    <div class="stat-value"><%= stats.pendingApplications %></div>
                    <div class="stat-label">Pending Review</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-value"><%= stats.approvedApplications %></div>
                    <div class="stat-label">Approved Trusts</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-wallet"></i></div>
                    <div class="stat-value"><%= stats.availableWallets %></div>
                    <div class="stat-label">Available Wallets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-user-check"></i></div>
                    <div class="stat-value"><%= stats.assignedWallets %></div>
                    <div class="stat-label">Assigned Wallets</div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="quick-actions">
                <h3>Quick Actions</h3>
                <div class="action-buttons">
                    <a href="/admin/plans/create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Create Plan
                    </a>
                    <a href="/admin/trusts?status=pending" class="btn btn-outline">
                        <i class="fas fa-clock"></i> Pending Applications
                    </a>
                    <a href="/admin/trusts?status=pending" class="btn btn-outline">
                        <i class="fas fa-shield-haltered"></i> Pending Trusts
                    </a>
                    <a href="/admin/wallet-pool" class="btn btn-outline">
                        <i class="fas fa-plus-circle"></i> Add Wallets
                    </a>
                </div>
            </div>

            <!-- Recent Applications -->
            <div class="recent-section">
                <h3>Recent Trust Applications</h3>
                <% if (recentApplications && recentApplications.length > 0) { %>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Trust Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentApplications.forEach(app => { %>
                                <tr>
                                    <td>
                                        <%= app.userId?.fullName || 'N/A' %><br>
                                        <small><%= app.userId?.email || '' %></small>
                                    </td>
                                    <td><%= app.trustName %></td>
                                    <td><%= app.trustType ? app.trustType.replace(/_/g, ' ') : 'N/A' %></td>
                                    <td>
                                        <span class="badge badge-<%= app.status %>"><%= app.status.replace(/_/g, ' ') %></span>
                                    </td>
                                    <td><%= app.createdAt.toLocaleDateString() %></td>
                                    <td>
                                        <a href="/admin/trusts/<%= app._id %>" class="btn btn-outline btn-sm">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <div class="view-all">
                        <a href="/admin/trusts">View All Trust Applications <i class="fas fa-arrow-right"></i></a>
                    </div>
                <% } else { %>
                    <p class="no-data">No recent applications</p>
                <% } %>
            </div>
        </main>
    </div>

</body>
</html>