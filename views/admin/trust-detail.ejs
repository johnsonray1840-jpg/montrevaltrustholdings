<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Application Details | Montreval Trust Holdings</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/assets/css/libraries.css">
    <link rel="stylesheet" href="/assets/css/icons.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-dark: #223140;
            --brand-white: #ffffff;
            --brand-gray: #94a3b8;
            --brand-border: rgba(255, 255, 255, 0.08);
            --brand-bg: rgba(255, 255, 255, 0.03);
            --bg-dark: #0f172a;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-dark);
            font-family: 'DM Sans', sans-serif;
            color: #e2e8f0;
            min-height: 100vh;
        }

        .admin-header {
            background: var(--brand-dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-header .logo {
            color: var(--brand-white);
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .admin-layout {
            display: flex;
            min-height: calc(100vh - 64px);
        }

        .admin-sidebar {
            width: 250px;
            background: rgba(255,255,255,0.02);
            border-right: 1px solid var(--brand-border);
            padding: 20px 0;
            flex-shrink: 0;
        }

        .admin-sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.9rem;
            border-left: 3px solid transparent;
            transition: all 0.2s;
        }

        .admin-sidebar a:hover { background: rgba(255,255,255,0.03); color: var(--brand-white); }
        .admin-sidebar a.active { background: rgba(255,255,255,0.05); color: var(--brand-white); border-left-color: var(--brand-white); font-weight: 600; }
        .admin-sidebar a i { width: 20px; text-align: center; }

        .admin-main {
            flex: 1;
            padding: 30px;
            overflow-x: auto;
        }

        .back-link {
            color: var(--brand-gray);
            text-decoration: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
        }

        .back-link:hover { color: var(--brand-white); }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .page-header h1 {
            font-size: 1.6rem;
            color: var(--brand-white);
        }

        .badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .badge-pending { background: rgba(245,158,11,0.15); color: var(--warning); }
        .badge-approved { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-active { background: rgba(34,197,94,0.15); color: var(--success); }
        .badge-rejected { background: rgba(239,68,68,0.15); color: var(--danger); }
        .badge-draft { background: rgba(148,163,184,0.15); color: var(--brand-gray); }
        .badge-under_review { background: rgba(59,130,246,0.15); color: #60a5fa; }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        .detail-section {
            background: var(--brand-bg);
            border: 1px solid var(--brand-border);
            border-radius: 14px;
            padding: 22px;
        }

        .detail-section.full-width { grid-column: span 2; }

        .detail-section h3 {
            color: var(--brand-white);
            font-size: 1rem;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .detail-section h3 i { color: var(--brand-white); }

        .detail-table { width: 100%; }

        .detail-table th {
            text-align: left;
            width: 40%;
            color: var(--brand-gray);
            font-weight: 500;
            padding: 9px 0;
            font-size: 0.85rem;
        }

        .detail-table td {
            padding: 9px 0;
            color: var(--brand-white);
            font-size: 0.9rem;
        }

        .document-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .document-card {
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--brand-border);
            border-radius: 10px;
            overflow: hidden;
        }

        .document-card img, .document-card embed {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
        }

        .doc-label {
            padding: 10px;
            text-align: center;
            font-size: 0.85rem;
            color: var(--brand-gray);
        }

        .doc-label a { color: var(--brand-white); }

        .action-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .btn {
            padding: 12px 22px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-success { background: var(--success); color: #fff; }
        .btn-success:hover { background: #16a34a; }

        .btn-danger { background: rgba(239,68,68,0.15); color: var(--danger); border: 1px solid rgba(239,68,68,0.3); }
        .btn-danger:hover { background: rgba(239,68,68,0.25); }

        .btn-outline { background: transparent; border: 1px solid var(--brand-border); color: var(--brand-white); }
        .btn-outline:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); }

        .btn-lg { padding: 14px 28px; font-size: 1rem; }

        .admin-notes-box {
            background: rgba(239,68,68,0.05);
            border: 1px dashed rgba(239,68,68,0.3);
            padding: 16px;
            border-radius: 10px;
            margin-top: 20px;
        }

        .admin-notes-box h4 { color: var(--brand-white); margin-bottom: 6px; }
        .admin-notes-box p { color: var(--brand-gray); }

        .text-muted { color: var(--brand-gray); }

        /* Modal */
        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-content {
            background: #1a1f2e;
            border: 1px solid var(--brand-border);
            border-radius: 16px;
            padding: 30px;
            max-width: 480px;
            width: 90%;
        }

        .modal-content h3 { color: var(--brand-white); margin-bottom: 10px; }
        .modal-content p { color: var(--brand-gray); margin-bottom: 15px; }

        .modal-content textarea {
            width: 100%;
            padding: 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--brand-border);
            border-radius: 10px;
            color: var(--brand-white);
            resize: vertical;
            font-family: inherit;
            font-size: 0.9rem;
        }

        .modal-content textarea:focus { outline: none; border-color: rgba(255,255,255,0.3); }

        .modal-actions { display: flex; gap: 10px; margin-top: 15px; justify-content: flex-end; }

        @media (max-width: 768px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--brand-border); }
            .admin-main { padding: 20px 15px; }
            .detail-grid { grid-template-columns: 1fr; }
            .detail-section.full-width { grid-column: span 1; }
        }
    </style>
</head>
<body>

    <header class="admin-header">
        <a href="/admin/dashboard" class="logo">
            <i class="fas fa-shield-haltered"></i> MONTREVAL
        </a>
        <a href="/auth/logout" style="color:var(--brand-gray);text-decoration:none;font-size:0.85rem;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </header>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav>
                <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin/kyc"><i class="fas fa-id-card"></i> KYC Verification</a>
                <a href="/admin/plans"><i class="fas fa-box"></i> Plans</a>
                <a href="/admin/trusts" class="active"><i class="fas fa-file-alt"></i>Trust Applications</a>
                <!-- <a href="/admin/trusts"><i class="fas fa-shield-haltered"></i> Trust Management</a> -->
                <a href="/admin/withdrawals"><i class="fas fa-money-bill-wave"></i> Withdrawals</a>
                <a href="/admin/wallet-pool"><i class="fas fa-wallet"></i> Wallet Pool</a>
                <a href="/admin/users"><i class="fas fa-users"></i> Users</a>
            </nav>
        </aside>

        <main class="admin-main">
            <a href="/admin/trusts" class="back-link"><i class="fas fa-arrow-left"></i> Back to Trust Applications</a>

            <div class="page-header">
                <h1>Application Details</h1>
                <span class="badge badge-<%= application.status %>" style="font-size:0.9rem;"><%= application.status.replace(/_/g, ' ') %></span>
            </div>

            <div class="detail-grid">
                <!-- Applicant -->
                <div class="detail-section">
                    <h3><i class="fas fa-user"></i> Applicant</h3>
                    <table class="detail-table">
                        <tr><th>Name</th><td><%= application.userId?.fullName || 'N/A' %></td></tr>
                        <tr><th>Email</th><td><%= application.userId?.email || 'N/A' %></td></tr>
                        <tr><th>Phone</th><td><%= application.userId?.phone || '—' %></td></tr>
                    </table>
                </div>

                <!-- Trust Info -->
                <div class="detail-section">
                    <h3><i class="fas fa-shield-haltered"></i> Trust Information</h3>
                    <table class="detail-table">
                        <tr><th>Trust Name</th><td><strong><%= application.trustName %></strong></td></tr>
                        <tr><th>Trust Type</th><td><%= application.trustType ? application.trustType.replace(/_/g, ' ') : 'N/A' %></td></tr>
                        <tr><th>Jurisdiction</th><td><%= application.jurisdiction || 'N/A' %></td></tr>
                        <tr><th>Purpose</th><td><%= application.trustPurpose ? application.trustPurpose.replace(/_/g, ' ') : 'N/A' %></td></tr>
                    </table>
                </div>

                <!-- Settlor -->
                <div class="detail-section">
                    <h3><i class="fas fa-user-circle"></i> Settlor (Grantor)</h3>
                    <table class="detail-table">
                        <tr><th>Name</th><td><%= application.settlor?.fullName || 'N/A' %></td></tr>
                        <tr><th>DOB</th><td><%= application.settlor?.dateOfBirth ? new Date(application.settlor.dateOfBirth).toLocaleDateString() : 'N/A' %></td></tr>
                        <tr><th>Nationality</th><td><%= application.settlor?.nationality || 'N/A' %></td></tr>
                        <tr><th>Address</th><td><%= application.settlor?.address?.street || '' %>, <%= application.settlor?.address?.city || '' %>, <%= application.settlor?.address?.country || '' %></td></tr>
                    </table>
                </div>

                <!-- Trustee -->
                <div class="detail-section">
                    <h3><i class="fas fa-user-tie"></i> Trustee</h3>
                    <table class="detail-table">
                        <tr><th>Type</th><td><%= application.trustee?.type === 'montreval' ? 'Montreval Trust Holdings' : application.trustee?.type || 'N/A' %></td></tr>
                        <% if (application.trustee?.type !== 'montreval') { %>
                        <tr><th>Name</th><td><%= application.trustee?.fullName || '—' %></td></tr>
                        <tr><th>Email</th><td><%= application.trustee?.email || '—' %></td></tr>
                        <% } %>
                        <tr><th>Successor</th><td><%= application.successorTrustee || '—' %></td></tr>
                    </table>
                </div>

                <!-- Beneficiaries -->
                <div class="detail-section">
                    <h3><i class="fas fa-users"></i> Beneficiaries</h3>
                    <% if (application.beneficiaries?.length) { %>
                        <table class="detail-table">
                            <% application.beneficiaries.forEach(b => { %>
                                <tr><th><%= b.name %></th><td><%= b.relationship.replace(/_/g, ' ') %> — <%= b.allocation %>%</td></tr>
                            <% }) %>
                        </table>
                    <% } else { %>
                        <p class="text-muted">None listed</p>
                    <% } %>
                </div>

                <!-- Assets -->
                <div class="detail-section">
                    <h3><i class="fas fa-coins"></i> Assets & Value</h3>
                    <table class="detail-table">
                        <tr><th>Est. Value</th><td><%= application.estimatedValue || 'N/A' %></td></tr>
                        <tr><th>Asset Types</th><td><%= application.assetTypes?.length ? application.assetTypes.join(', ').replace(/_/g, ' ') : 'N/A' %></td></tr>
                        <tr><th>Source of Funds</th><td><%= application.sourceOfFunds ? application.sourceOfFunds.replace(/_/g, ' ') : 'N/A' %></td></tr>
                    </table>
                </div>

                <!-- Documents -->
                <div class="detail-section full-width">
                    <h3><i class="fas fa-file-upload"></i> Documents</h3>
                    <% if (application.documents?.length) { %>
                        <div class="document-grid">
                            <% application.documents.forEach((doc, index) => { %>
                                <div class="document-card">
                                    <% const ext = doc.fileName.split('.').pop().toLowerCase(); %>
                                    <% if (['jpg','jpeg','png','gif'].includes(ext)) { %>
                                        <img src="/admin/trusts/document/<%= application._id %>/<%= index %>" alt="<%= doc.fileName %>">
                                    <% } else { %>
                                        <embed src="/admin/trusts/document/<%= application._id %>/<%= index %>" width="100%" height="200px">
                                    <% } %>
                                    <div class="doc-label">
                                        <%= doc.fileName %>
                                        <a href="/admin/trusts/document/<%= application._id %>/<%= index %>" target="_blank"><i class="fas fa-external-link-alt"></i></a>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p class="text-muted">No documents uploaded.</p>
                    <% } %>
                </div>

                <!-- Timeline -->
                <div class="detail-section full-width">
                    <h3><i class="fas fa-history"></i> Timeline</h3>
                    <table class="detail-table">
                        <tr><th>Created</th><td><%= application.createdAt?.toLocaleString() || '—' %></td></tr>
                        <tr><th>Submitted</th><td><%= application.submittedAt ? application.submittedAt.toLocaleString() : '—' %></td></tr>
                        <% if (application.approvedAt) { %><tr><th>Approved</th><td><%= application.approvedAt.toLocaleString() %></td></tr><% } %>
                        <% if (application.rejectedAt) { %><tr><th>Rejected</th><td><%= application.rejectedAt.toLocaleString() %></td></tr><% } %>
                        <% if (application.rejectionReason) { %><tr><th>Reason</th><td><%= application.rejectionReason %></td></tr><% } %>
                    </table>
                </div>
            </div>

            <!-- Actions -->
            <div class="action-bar">
                <% if (application.status === 'pending') { %>
                    <form action="/admin/trusts/<%= application._id %>/approve" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-check-circle"></i> Approve
                        </button>
                    </form>
                    <button type="button" class="btn btn-danger show-reject-modal"
                            data-app-id="<%= application._id %>"
                            data-trust-name="<%= application.trustName %>">
                        <i class="fas fa-times-circle"></i> Reject
                    </button>
                <% } %>
                <form action="/admin/trusts/<%= application._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this application?')">
                    <button type="submit" class="btn btn-outline"><i class="fas fa-trash"></i> Delete</button>
                </form>
            </div>

            <% if (application.adminNotes) { %>
                <div class="admin-notes-box">
                    <h4>Admin Notes</h4>
                    <p><%= application.adminNotes %></p>
                </div>
            <% } %>
        </main>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="modal">
        <div class="modal-content">
            <h3>Reject Application</h3>
            <p>Trust: <strong id="modalTrustName" style="color:var(--brand-white);"></strong></p>
            <form id="rejectForm" method="POST">
                <textarea name="rejectionReason" placeholder="Reason for rejection (emailed to user)" rows="4" required></textarea>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-outline hide-reject-modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('rejectModal');
        const modalTrustName = document.getElementById('modalTrustName');
        const rejectForm = document.getElementById('rejectForm');

        document.querySelectorAll('.show-reject-modal').forEach(btn => {
            btn.addEventListener('click', function() {
                const appId = this.getAttribute('data-app-id');
                const trustName = this.getAttribute('data-trust-name');
                modalTrustName.textContent = trustName;
                rejectForm.action = '/admin/trusts/' + appId + '/reject';
                modal.style.display = 'flex';
            });
        });

        document.querySelectorAll('.hide-reject-modal').forEach(btn => {
            btn.addEventListener('click', () => modal.style.display = 'none');
        });

        modal.addEventListener('click', function(e) {
            if (e.target === modal) modal.style.display = 'none';
        });
    </script>
</body>
</html>