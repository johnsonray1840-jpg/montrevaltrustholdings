  <style>
    /* ============ AUTH BACKGROUND ============ */
    .auth_section {
      min-height: 100vh;
      display: flex;
      align-items: center;
      background:
        radial-gradient(circle at top left, rgba(0, 180, 255, 0.12), transparent 45%),
        radial-gradient(circle at bottom right, rgba(120, 80, 255, 0.10), transparent 50%),
        #0b1220;
      position: relative;
      overflow: hidden;
    }

    .auth_section::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 70%, rgba(240, 185, 11, 0.03) 0%, transparent 50%);
      pointer-events: none;
    }

    /* ============ GLASS CARD ============ */
    .auth_glass_card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      box-shadow: 0 25px 70px rgba(0, 0, 0, 0.4);
      color: #fff;
      position: relative;
      z-index: 1;
    }

    /* ============ HEADER ============ */
    .auth_header {
      margin-bottom: 30px;
    }

    .auth_header h5 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 8px;
    }

    .auth_header .welcome-text {
      color: #8892a8;
      font-size: 0.95rem;
      margin-bottom: 0;
    }

    /* ============ SWITCH LINK ============ */
    .auth_switch {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 25px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .auth_switch span {
      color: #8892a8;
      font-size: 0.9rem;
    }

    .auth_switch a {
      color: #f0b90b;
      font-weight: 600;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 5px;
      transition: color 0.3s;
    }

    .auth_switch a:hover {
      color: #f59e0b;
    }

    /* ============ ALERTS ============ */
    .alert {
      padding: 14px 18px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid transparent;
    }

    .alert-error {
      background: rgba(220, 53, 69, 0.12);
      border-color: rgba(220, 53, 69, 0.3);
      color: #f87171;
    }

    .alert-success {
      background: rgba(40, 167, 69, 0.12);
      border-color: rgba(40, 167, 69, 0.3);
      color: #4ade80;
    }

    .alert i {
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    /* ============ INPUTS ============ */
    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      color: #cbd5e1;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .auth_input {
      width: 100%;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      outline: none;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    .auth_input::placeholder {
      color: rgba(255, 255, 255, 0.4);
    }

    .auth_input:focus {
      border-color: rgba(240, 185, 11, 0.5);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 20px rgba(240, 185, 11, 0.08);
    }

    /* ============ PASSWORD WRAPPER ============ */
    .password-wrapper {
      position: relative;
    }

    .password-wrapper .auth_input {
      padding-right: 45px;
    }

    .password-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      cursor: pointer;
      font-size: 1.1rem;
      padding: 8px;
      z-index: 2;
      transition: color 0.3s;
    }

    .password-toggle:hover {
      color: #f0b90b;
    }

    /* ============ PASSWORD STRENGTH METER ============ */
    .strength-meter {
      margin-top: 8px;
      height: 4px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 2px;
      overflow: hidden;
    }

    .strength-meter-fill {
      height: 100%;
      width: 0%;
      border-radius: 2px;
      transition: width 0.3s, background 0.3s;
    }

    .strength-text {
      font-size: 0.75rem;
      margin-top: 4px;
      display: block;
      color: #8892a8;
    }

    /* ============ CHECKBOX ============ */
    .checkbox-group {
      margin-bottom: 25px;
    }

    .checkbox-label {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: #cbd5e1;
      font-size: 0.85rem;
      cursor: pointer;
      line-height: 1.5;
    }

    .checkbox-label input[type="checkbox"] {
      width: 18px;
      height: 18px;
      margin-top: 2px;
      accent-color: #f0b90b;
      cursor: pointer;
      flex-shrink: 0;
    }

    .checkbox-label a {
      color: #f0b90b;
      text-decoration: none;
      font-weight: 500;
    }

    .checkbox-label a:hover {
      text-decoration: underline;
    }

    /* ============ SUBMIT BUTTON ============ */
    .btn-submit {
      width: 100%;
      padding: 14px;
      border-radius: 12px;
      background: linear-gradient(135deg, #f0b90b, #f59e0b);
      color: #000;
      font-weight: 600;
      font-size: 1rem;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-submit:hover {
      background: linear-gradient(135deg, #f59e0b, #f0b90b);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(240, 185, 11, 0.25);
    }

    /* ============ FORM FOOTER ============ */
    .auth_footer {
      text-align: center;
      margin-top: 25px;
      padding-top: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .auth_footer p {
      color: #8892a8;
      font-size: 0.9rem;
      margin-bottom: 0;
    }

    .auth_footer a {
      color: #f0b90b;
      font-weight: 600;
      text-decoration: none;
    }

    .auth_footer a:hover {
      text-decoration: underline;
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 576px) {
      .auth_glass_card {
        padding: 25px 20px !important;
      }

      .auth_header h5 {
        font-size: 1.3rem;
      }
    }
  </style>
