<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <meta name="description"
    content="Montreval Trust Holdings provides secure wealth management, investment planning, asset protection, retirement strategies, and trusted financial solutions for individuals and businesses worldwide." />

  <link rel="icon" href="/images/favicon.png">

  <title>404 - Page Not Found | Montreval Trust Holdings</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700">

  <link rel="stylesheet" href="/assets/css/libraries.css">
  <link rel="stylesheet" href="/assets/css/icons.css">
  <link rel="stylesheet" href="/assets/css/style.css">

  <style>
    .error-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      background: #0a0e17;
      position: relative;
      overflow: hidden;
    }
    
    .error-page .bg-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 50% 50%, rgba(240, 185, 11, 0.05) 0%, transparent 70%);
    }
    
    .error-code {
      font-size: 180px;
      font-weight: 700;
      line-height: 1;
      background: linear-gradient(135deg, #f0b90b, #f59e0b);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 10px;
      opacity: 0.95;
    }
    
    .error-title {
      font-size: 2.5rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 20px;
    }
    
    .error-desc {
      font-size: 1.1rem;
      color: #8892a8;
      margin-bottom: 40px;
      line-height: 1.8;
    }
    
    .error-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }
    
    @media (max-width: 768px) {
      .error-code {
        font-size: 120px;
      }
      .error-title {
        font-size: 1.8rem;
      }
    }
  </style>
</head>

<body>

  <div class="error-page">
    <div class="bg-overlay"></div>
    
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-sm-12 col-md-10 col-lg-8 col-xl-6 text-center">
          
          <!-- Logo -->
          <a href="/" class="d-inline-block mb-50">
            <img src="/images/logo-light.png" alt="Montreval Trust Holdings" width="200">
          </a>
          
          <!-- Error Code -->
          <div class="error-code">404</div>
          
          <!-- Title -->
          <h1 class="error-title">Page Not Found</h1>
          
          <!-- Description -->
          <p class="error-desc">
            The page you're looking for doesn't exist or has been moved. 
            Let us help you find your way back to securing your financial future.
          </p>
          
          <!-- Action Buttons -->
          <div class="error-actions">
            <a href="/" class="btn btn-white btn-white-style2 arrow-hover-flip-right">
              <span>Return Home</span>
              <span class="btn-icon">
                <svg viewBox="0 0 17 11" xmlns="http://www.w3.org/2000/svg" width="15" height="15">
                  <path class="arrow-flip-path-1" fill="currentColor"
                    d="M11.5248 10.309C11.2695 10.0543 11.2695 9.64136 11.5248 9.38667L14.7676 6.15217H0.653846C0.292737 6.15217 0 5.86019 0 5.5C0 5.13981 0.292737 4.84783 0.653846 4.84783H14.7676L11.5248 1.61333C11.2695 1.35864 11.2695 0.945707 11.5248 0.691017C11.7802 0.436327 12.1942 0.436328 12.4495 0.691018L16.8085 5.03884C17.0638 5.29353 17.0638 5.70647 16.8085 5.96116L12.4495 10.309C12.1942 10.5637 11.7802 10.5637 11.5248 10.309Z">
                  </path>
                  <path class="arrow-flip-path-2" fill="currentColor"
                    d="M11.5248 10.309C11.2695 10.0543 11.2695 9.64136 11.5248 9.38667L14.7676 6.15217H0.653846C0.292737 6.15217 0 5.86019 0 5.5C0 5.13981 0.292737 4.84783 0.653846 4.84783H14.7676L11.5248 1.61333C11.2695 1.35864 11.2695 0.945707 11.5248 0.691017C11.7802 0.436327 12.1942 0.436328 12.4495 0.691018L16.8085 5.03884C17.0638 5.29353 17.0638 5.70647 16.8085 5.96116L12.4495 10.309C12.1942 10.5637 11.7802 10.5637 11.5248 10.309Z">
                  </path>
                </svg>
              </span>
            </a>
            
            <a href="/contact" class="btn btn-white btn-outlined">
              Contact Support
            </a>
          </div>
          
        </div>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="/assets/js/libraries.js"></script>
  <script src="/assets/js/main.js"></script>

</body>
</html>