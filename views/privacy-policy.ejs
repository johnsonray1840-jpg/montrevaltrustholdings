<section class="blog_details pt-120 pb-120 bg9-color">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="terms_condition__content">

                    <!-- Introduction -->
                    <h3 class="mb-5 wow fadeInUp">Introduction</h3>
                    <p class="mb-6 wow fadeInUp">
                        We are committed to protecting your personal information and maintaining your trust. This Privacy Policy outlines how we collect, use, and safeguard your data when you access our website or engage our trust and estate planning services.
                    </p>
                    <hr class="bg2-color mb-10">

                    <!-- Information We Collect -->
                    <h3 class="mb-5 wow fadeInUp">Information We Collect</h3>
                    <p class="mb-6 wow fadeInUp">
                        We may collect personal information that you voluntarily provide, including:
                    </p>
                    <ul class="mb-6 wow fadeInUp">
                        <li>Full name</li>
                        <li>Email address</li>
                        <li>Phone number</li>
                        <li>Financial and asset-related information (when necessary for trust planning)</li>
                        <li>Any details submitted through consultation forms</li>
                    </ul>
                    <hr class="bg2-color mb-10">

                    <!-- How We Use Information -->
                    <h3 class="mb-5 wow fadeInUp">How We Use Your Information</h3>
                    <p class="mb-6 wow fadeInUp">
                        Your information is used strictly for professional and operational purposes, including:
                    </p>
                    <ul class="mb-6 wow fadeInUp">
                        <li>Providing trust and estate planning services</li>
                        <li>Responding to inquiries and consultation requests</li>
                        <li>Preparing legal and financial structures</li>
                        <li>Improving our services and client experience</li>
                    </ul>
                    <hr class="bg2-color mb-10">

                    <!-- Data Protection -->
                    <h3 class="mb-5 wow fadeInUp">Data Protection & Security</h3>
                    <p class="mb-6 wow fadeInUp">
                        We implement appropriate security measures to protect your personal information from unauthorized access, disclosure, or misuse. All sensitive data is handled with strict confidentiality in accordance with professional standards.
                    </p>
                    <hr class="bg2-color mb-10">

                    <!-- Sharing Information -->
                    <h3 class="mb-5 wow fadeInUp">Sharing of Information</h3>
                    <p class="mb-6 wow fadeInUp">
                        We do not sell, trade, or rent your personal information. Information may only be shared when necessary with trusted professionals or legal entities involved in structuring your trust, and only where required.
                    </p>
                    <hr class="bg2-color mb-10">

                    <!-- Cookies -->
                    <h3 class="mb-5 wow fadeInUp">Cookies & Website Data</h3>
                    <p class="mb-6 wow fadeInUp">
                        Our website may use cookies or analytics tools to improve user experience and monitor performance. This data does not personally identify you and is used solely for optimization purposes.
                    </p>
                    <hr class="bg2-color mb-10">

                    <!-- User Rights -->
                    <h3 class="mb-5 wow fadeInUp">Your Rights</h3>
                    <p class="mb-6 wow fadeInUp">
                        You have the right to:
                    </p>
                    <ul class="mb-6 wow fadeInUp">
                        <li>Request access to your personal data</li>
                        <li>Request correction or deletion of your data</li>
                        <li>Withdraw consent where applicable</li>
                    </ul>
                    <hr class="bg2-color mb-10">

                    <!-- Policy Updates -->
                    <h3 class="mb-5 wow fadeInUp">Policy Updates</h3>
                    <p class="mb-6 wow fadeInUp">
                        We may update this Privacy Policy periodically to reflect changes in our services or legal requirements. Updates will be posted on this page with a revised effective date.
                    </p>
                    <hr class="bg2-color mb-10">

                    <!-- Contact -->
                    <h3 class="mb-5 wow fadeInUp">Contact Us</h3>
                    <p class="mb-6 wow fadeInUp">
                        If you have any questions regarding this Privacy Policy or how your information is handled, please contact us through our official contact page.
                    </p>

                </div>

                <!-- Highlight Quote -->
                <div class="blog_details__quet rounded-20 br2 bg1-color mt-10">
                    <p class="fs-four py-10 px-10 text-center wow fadeInUp">
                        "Your privacy and financial security are at the core of our trust planning services."
                    </p>
                </div>

            </div>
        </div>
    </div>
</section>
